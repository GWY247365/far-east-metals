              <!-- Bottom label -->
              <text x="250" y="130" text-anchor="middle" font-size="10" fill="#888" font-family="var(--font-main)">Typical T6 process: Solution treat &rarr; Quench &rarr; Artificially age</text>
              <text x="250" y="148" text-anchor="middle" font-size="9" fill="#aaa" font-family="var(--font-main)">T4 = Natural aging (room temperature) instead of artificial aging</text>
