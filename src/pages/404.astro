---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Page Not Found | Far East Metals" description="The page you are looking for could not be found.">
  <section class="error-page">
    <div class="content-card error-card reveal">
      <!-- Animated SVG: broken metal piece -->
      <svg class="error-svg" viewBox="0 0 240 180" xmlns="http://www.w3.org/2000/svg">
        <!-- Left piece -->
        <g class="piece-left">
          <path d="M30 50 L110 50 L115 80 L108 110 L118 140 L30 140 Z" fill="none" stroke="#ccc" stroke-width="2" rx="4"/>
          <path d="M30 50 L110 50 L115 80 L108 110 L118 140 L30 140 Z" fill="rgba(245,166,35,0.06)"/>
          <line x1="50" y1="70" x2="100" y2="70" stroke="#ddd" stroke-width="1.5" stroke-dasharray="4 3"/>
          <line x1="50" y1="90" x2="95" y2="90" stroke="#ddd" stroke-width="1.5"/>
          <line x1="50" y1="110" x2="105" y2="110" stroke="#ddd" stroke-width="1.5" stroke-dasharray="4 3"/>
        </g>
        <!-- Right piece -->
        <g class="piece-right">
          <path d="M130 50 L210 50 L210 140 L128 140 L122 110 L130 80 Z" fill="none" stroke="#ccc" stroke-width="2"/>
          <path d="M130 50 L210 50 L210 140 L128 140 L122 110 L130 80 Z" fill="rgba(245,166,35,0.04)"/>
          <line x1="145" y1="70" x2="195" y2="70" stroke="#ddd" stroke-width="1.5" stroke-dasharray="4 3"/>
          <line x1="140" y1="90" x2="195" y2="90" stroke="#ddd" stroke-width="1.5"/>
          <line x1="142" y1="110" x2="195" y2="110" stroke="#ddd" stroke-width="1.5" stroke-dasharray="4 3"/>
        </g>
        <!-- Question mark -->
        <text class="question-mark" x="120" y="170" text-anchor="middle" font-size="18" fill="#F5A623" opacity="0.6">?</text>
      </svg>

      <div class="error-number">404</div>
      <h1 class="page-title" style="margin-bottom: 12px;">Page Not Found</h1>
      <p class="error-description">
        The page you are looking for may have been moved or does not exist.
      </p>

      <div class="error-actions">
        <a href="/" class="home-button">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 12l9-9 9 9"/><path d="M5 10v10a1 1 0 001 1h4v-6h4v6h4a1 1 0 001-1V10"/></svg>
          Back to Home
        </a>
        <a href="/contact/" class="contact-link">Contact Us</a>
      </div>

      <div class="quick-links">
        <p class="quick-links-title">Or try one of these:</p>
        <div class="quick-links-grid">
          <a href="/about/" class="quick-link">About</a>
          <a href="/alloycompare/" class="quick-link">Alloy Comparison</a>
          <a href="/hardnessconverter/" class="quick-link">Hardness Converter</a>
          <a href="/metweighcalculator/" class="quick-link">Weight Calculator</a>
          <a href="/temperguide/" class="quick-link">Temper Guide</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .error-page {
    padding: 100px 20px 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 160px);
  }

  .error-card {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 50px 40px;
    max-width: 600px;
    width: 100%;
  }

  .error-svg {
    width: 200px;
    height: 150px;
    margin-bottom: 10px;
  }

  .piece-left {
    animation: drift-left 3s ease-in-out infinite;
  }

  .piece-right {
    animation: drift-right 3s ease-in-out infinite;
  }

  .question-mark {
    animation: fade-pulse 2s ease-in-out infinite;
  }

  @keyframes drift-left {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-6px, 2px); }
  }

  @keyframes drift-right {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(6px, -2px); }
  }

  @keyframes fade-pulse {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 0.2; }
  }

  .error-number {
    font-size: 5rem;
    font-weight: 700;
    font-family: var(--font-title);
    line-height: 1;
    margin-bottom: 8px;
    background: linear-gradient(135deg, var(--color-accent), #d4891a);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .error-description {
    font-size: 0.95rem;
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: 28px;
    max-width: 420px;
  }

  .error-actions {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 36px;
  }

  .home-button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 28px;
    background: linear-gradient(135deg, var(--color-accent), #d4891a);
    color: white;
    text-decoration: none;
    border-radius: 12px;
    font-size: 0.95rem;
    font-weight: 600;
    transition: all 0.3s;
    box-shadow: 0 4px 15px rgba(245, 166, 35, 0.2);
  }

  .home-button:hover {
    background: linear-gradient(135deg, #d4891a, #c07818);
    box-shadow: 0 6px 20px rgba(245, 166, 35, 0.3);
    transform: translateY(-2px);
  }

  .contact-link {
    padding: 12px 28px;
    color: var(--color-text);
    text-decoration: none;
    border: 1.5px solid rgba(0,0,0,0.12);
    border-radius: 12px;
    font-size: 0.95rem;
    font-weight: 500;
    transition: all 0.3s;
  }

  .contact-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: translateY(-2px);
  }

  .quick-links {
    width: 100%;
    border-top: 1px solid rgba(0,0,0,0.06);
    padding-top: 24px;
  }

  .quick-links-title {
    font-size: 0.8rem;
    color: var(--color-text-light);
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .quick-links-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
  }

  .quick-link {
    padding: 6px 16px;
    background: rgba(245,166,35,0.06);
    border: 1px solid rgba(245,166,35,0.15);
    border-radius: 20px;
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 500;
    transition: all 0.25s;
  }

  .quick-link:hover {
    background: rgba(245,166,35,0.15);
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .error-card {
      padding: 40px 24px;
    }

    .error-number {
      font-size: 4rem;
    }

    .error-actions {
      flex-direction: column;
      width: 100%;
    }

    .home-button,
    .contact-link {
      width: 100%;
      justify-content: center;
      text-align: center;
    }
  }
</style>
