<div class="download-modal-overlay" id="downloadModal" hidden>
  <div class="download-modal">
    <button class="download-modal-close" id="closeDownloadModal">&times;</button>
    <h3>Download Our Brochure</h3>
    <p>Please provide your details to download our company brochure.</p>
    <form id="downloadForm">
      <div class="dm-field">
        <label for="dm-name">Name *</label>
        <input type="text" id="dm-name" name="name" required />
      </div>
      <div class="dm-field">
        <label for="dm-email">Email *</label>
        <input type="email" id="dm-email" name="email" required />
      </div>
      <div class="dm-field">
        <label for="dm-company">Company</label>
        <input type="text" id="dm-company" name="company" />
      </div>
      <button type="submit" class="dm-submit">Download Brochure</button>
    </form>
  </div>
</div>

<style>
  .download-modal-overlay[hidden] {
    display: none !important;
  }

  .download-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    animation: dmFadeIn 0.3s ease;
  }

  @keyframes dmFadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes dmScaleIn {
    from {
      opacity: 0;
      transform: scale(0.92);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .download-modal {
    background: rgba(255, 255, 255, 0.95);
    border-radius: 20px;
    padding: 40px;
    max-width: 440px;
    width: 90%;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
    position: relative;
    animation: dmScaleIn 0.3s ease;
  }

  .download-modal-close {
    position: absolute;
    top: 16px;
    right: 20px;
    background: none;
    border: none;
    font-size: 1.6rem;
    cursor: pointer;
    color: rgba(0, 0, 0, 0.4);
    line-height: 1;
    padding: 4px 8px;
    transition: color 0.2s;
  }

  .download-modal-close:hover {
    color: rgba(0, 0, 0, 0.8);
  }

  .download-modal h3 {
    font-family: var(--font-title, 'Barlow Condensed', sans-serif);
    font-size: 1.6rem;
    font-weight: 500;
    margin: 0 0 8px;
    color: #1a1a1a;
  }

  .download-modal p {
    font-family: var(--font-main, 'Barlow', sans-serif);
    font-size: 0.95rem;
    color: rgba(0, 0, 0, 0.6);
    margin: 0 0 24px;
    line-height: 1.5;
  }

  .dm-field {
    margin-bottom: 16px;
  }

  .dm-field label {
    display: block;
    font-family: var(--font-main, 'Barlow', sans-serif);
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(0, 0, 0, 0.7);
    margin-bottom: 6px;
  }

  .dm-field input {
    width: 100%;
    padding: 12px 16px;
    border: 1.5px solid rgba(0, 0, 0, 0.1);
    border-radius: 10px;
    font-family: var(--font-main, 'Barlow', sans-serif);
    font-size: 0.95rem;
    color: #1a1a1a;
    background: rgba(255, 255, 255, 0.8);
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
    outline: none;
  }

  .dm-field input:focus {
    border-color: var(--color-accent, #F5A623);
    box-shadow: 0 0 0 3px rgba(245, 166, 35, 0.15);
  }

  .dm-submit {
    width: 100%;
    margin-top: 8px;
    padding: 14px 28px;
    background: var(--color-accent, #F5A623);
    color: white;
    border: none;
    border-radius: 10px;
    font-family: var(--font-main, 'Barlow', sans-serif);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
  }

  .dm-submit:hover {
    opacity: 0.9;
  }

  .dm-submit:active {
    transform: scale(0.98);
  }
</style>

<script>
  const modal = document.getElementById('downloadModal');
  const form = document.getElementById('downloadForm');
  const closeBtn = document.getElementById('closeDownloadModal');

  // All download links trigger modal
  document.querySelectorAll('a[href="/brochure.pdf"]').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      if (localStorage.getItem('brochure_downloaded')) {
        // Already filled form, download directly
        const a = document.createElement('a');
        a.href = '/brochure.pdf';
        a.download = 'Far_East_Metals_Brochure.pdf';
        a.click();
        return;
      }
      modal?.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
    });
  });

  closeBtn?.addEventListener('click', () => {
    modal?.setAttribute('hidden', '');
    document.body.style.overflow = '';
  });

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
      modal.setAttribute('hidden', '');
      document.body.style.overflow = '';
    }
  });

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    localStorage.setItem('brochure_downloaded', 'true');
    modal?.setAttribute('hidden', '');
    document.body.style.overflow = '';
    // Trigger download
    const a = document.createElement('a');
    a.href = '/brochure.pdf';
    a.download = 'Far_East_Metals_Brochure.pdf';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
  });
</script>
