---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Aluminum Alloy Comparison Tool | Far East Metals" description="Compare aluminum alloy properties side by side. Comprehensive data for 1xxx-7xxx series alloys including mechanical properties, thermal conductivity, and applications.">
  <section class="alloy-page page-section">

    <!-- Animated Header -->
    <div class="alloy-header reveal">
      <div class="header-illustration">
        <svg viewBox="0 0 600 140" class="lattice-svg" aria-hidden="true">
          <!-- Crystal lattice structure -->
          <defs>
            <radialGradient id="nodeGlow" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#F5A623" stop-opacity="0.9"/>
              <stop offset="100%" stop-color="#F5A623" stop-opacity="0"/>
            </radialGradient>
            <linearGradient id="bondGrad" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#F5A623" stop-opacity="0.6"/>
              <stop offset="50%" stop-color="#F5A623" stop-opacity="0.2"/>
              <stop offset="100%" stop-color="#F5A623" stop-opacity="0.6"/>
            </linearGradient>
          </defs>
          <!-- Row 1 atoms -->
          <circle cx="80" cy="35" r="8" fill="#F5A623" opacity="0.25"><animate attributeName="r" values="8;10;8" dur="3s" repeatCount="indefinite"/></circle>
          <circle cx="80" cy="35" r="4" fill="#F5A623" opacity="0.7"><animate attributeName="opacity" values="0.7;1;0.7" dur="3s" repeatCount="indefinite"/></circle>
          <circle cx="160" cy="35" r="8" fill="#F5A623" opacity="0.25"><animate attributeName="r" values="8;10;8" dur="3s" repeatCount="indefinite" begin="0.3s"/></circle>
          <circle cx="160" cy="35" r="4" fill="#F5A623" opacity="0.7"/>
          <circle cx="240" cy="35" r="8" fill="#F5A623" opacity="0.25"><animate attributeName="r" values="8;10;8" dur="3s" repeatCount="indefinite" begin="0.6s"/></circle>
          <circle cx="240" cy="35" r="4" fill="#F5A623" opacity="0.7"/>
          <circle cx="320" cy="35" r="8" fill="#F5A623" opacity="0.25"><animate attributeName="r" values="8;10;8" dur="3s" repeatCount="indefinite" begin="0.9s"/></circle>
          <circle cx="320" cy="35" r="4" fill="#F5A623" opacity="0.7"/>
          <circle cx="400" cy="35" r="8" fill="#F5A623" opacity="0.25"><animate attributeName="r" values="8;10;8" dur="3s" repeatCount="indefinite" begin="1.2s"/></circle>
          <circle cx="400" cy="35" r="4" fill="#F5A623" opacity="0.7"/>
          <circle cx="480" cy="35" r="8" fill="#F5A623" opacity="0.25"><animate attributeName="r" values="8;10;8" dur="3s" repeatCount="indefinite" begin="1.5s"/></circle>
          <circle cx="480" cy="35" r="4" fill="#F5A623" opacity="0.7"/>
          <!-- Row 2 atoms (offset) -->
          <circle cx="120" cy="75" r="8" fill="#F5A623" opacity="0.2"><animate attributeName="r" values="8;10;8" dur="3s" repeatCount="indefinite" begin="0.5s"/></circle>
          <circle cx="120" cy="75" r="4" fill="#F5A623" opacity="0.6"/>
          <circle cx="200" cy="75" r="8" fill="#F5A623" opacity="0.2"><animate attributeName="r" values="8;10;8" dur="3s" repeatCount="indefinite" begin="0.8s"/></circle>
          <circle cx="200" cy="75" r="4" fill="#F5A623" opacity="0.6"/>
          <circle cx="280" cy="75" r="8" fill="#F5A623" opacity="0.2"><animate attributeName="r" values="8;10;8" dur="3s" repeatCount="indefinite" begin="1.1s"/></circle>
          <circle cx="280" cy="75" r="4" fill="#F5A623" opacity="0.6"/>
          <circle cx="360" cy="75" r="8" fill="#F5A623" opacity="0.2"><animate attributeName="r" values="8;10;8" dur="3s" repeatCount="indefinite" begin="1.4s"/></circle>
          <circle cx="360" cy="75" r="4" fill="#F5A623" opacity="0.6"/>
          <circle cx="440" cy="75" r="8" fill="#F5A623" opacity="0.2"><animate attributeName="r" values="8;10;8" dur="3s" repeatCount="indefinite" begin="1.7s"/></circle>
          <circle cx="440" cy="75" r="4" fill="#F5A623" opacity="0.6"/>
          <circle cx="520" cy="75" r="8" fill="#F5A623" opacity="0.2"><animate attributeName="r" values="8;10;8" dur="3s" repeatCount="indefinite" begin="2s"/></circle>
          <circle cx="520" cy="75" r="4" fill="#F5A623" opacity="0.6"/>
          <!-- Row 3 atoms -->
          <circle cx="80" cy="115" r="8" fill="#F5A623" opacity="0.15"><animate attributeName="r" values="8;10;8" dur="3s" repeatCount="indefinite" begin="1s"/></circle>
          <circle cx="80" cy="115" r="4" fill="#F5A623" opacity="0.5"/>
          <circle cx="160" cy="115" r="8" fill="#F5A623" opacity="0.15"/>
          <circle cx="160" cy="115" r="4" fill="#F5A623" opacity="0.5"/>
          <circle cx="240" cy="115" r="8" fill="#F5A623" opacity="0.15"/>
          <circle cx="240" cy="115" r="4" fill="#F5A623" opacity="0.5"/>
          <circle cx="320" cy="115" r="8" fill="#F5A623" opacity="0.15"/>
          <circle cx="320" cy="115" r="4" fill="#F5A623" opacity="0.5"/>
          <circle cx="400" cy="115" r="8" fill="#F5A623" opacity="0.15"/>
          <circle cx="400" cy="115" r="4" fill="#F5A623" opacity="0.5"/>
          <circle cx="480" cy="115" r="8" fill="#F5A623" opacity="0.15"/>
          <circle cx="480" cy="115" r="4" fill="#F5A623" opacity="0.5"/>
          <!-- Bonds row1-row2 -->
          <line x1="80" y1="35" x2="120" y2="75" stroke="url(#bondGrad)" stroke-width="1.5" opacity="0.4"/>
          <line x1="160" y1="35" x2="120" y2="75" stroke="url(#bondGrad)" stroke-width="1.5" opacity="0.4"/>
          <line x1="160" y1="35" x2="200" y2="75" stroke="url(#bondGrad)" stroke-width="1.5" opacity="0.4"/>
          <line x1="240" y1="35" x2="200" y2="75" stroke="url(#bondGrad)" stroke-width="1.5" opacity="0.4"/>
          <line x1="240" y1="35" x2="280" y2="75" stroke="url(#bondGrad)" stroke-width="1.5" opacity="0.4"/>
          <line x1="320" y1="35" x2="280" y2="75" stroke="url(#bondGrad)" stroke-width="1.5" opacity="0.4"/>
          <line x1="320" y1="35" x2="360" y2="75" stroke="url(#bondGrad)" stroke-width="1.5" opacity="0.4"/>
          <line x1="400" y1="35" x2="360" y2="75" stroke="url(#bondGrad)" stroke-width="1.5" opacity="0.4"/>
          <line x1="400" y1="35" x2="440" y2="75" stroke="url(#bondGrad)" stroke-width="1.5" opacity="0.4"/>
          <line x1="480" y1="35" x2="440" y2="75" stroke="url(#bondGrad)" stroke-width="1.5" opacity="0.4"/>
          <line x1="480" y1="35" x2="520" y2="75" stroke="url(#bondGrad)" stroke-width="1.5" opacity="0.4"/>
          <!-- Bonds row2-row3 -->
          <line x1="120" y1="75" x2="80" y2="115" stroke="url(#bondGrad)" stroke-width="1.5" opacity="0.3"/>
          <line x1="120" y1="75" x2="160" y2="115" stroke="url(#bondGrad)" stroke-width="1.5" opacity="0.3"/>
          <line x1="200" y1="75" x2="160" y2="115" stroke="url(#bondGrad)" stroke-width="1.5" opacity="0.3"/>
          <line x1="200" y1="75" x2="240" y2="115" stroke="url(#bondGrad)" stroke-width="1.5" opacity="0.3"/>
          <line x1="280" y1="75" x2="240" y2="115" stroke="url(#bondGrad)" stroke-width="1.5" opacity="0.3"/>
          <line x1="280" y1="75" x2="320" y2="115" stroke="url(#bondGrad)" stroke-width="1.5" opacity="0.3"/>
          <line x1="360" y1="75" x2="320" y2="115" stroke="url(#bondGrad)" stroke-width="1.5" opacity="0.3"/>
          <line x1="360" y1="75" x2="400" y2="115" stroke="url(#bondGrad)" stroke-width="1.5" opacity="0.3"/>
          <line x1="440" y1="75" x2="400" y2="115" stroke="url(#bondGrad)" stroke-width="1.5" opacity="0.3"/>
          <line x1="440" y1="75" x2="480" y2="115" stroke="url(#bondGrad)" stroke-width="1.5" opacity="0.3"/>
          <!-- Horizontal bonds -->
          <line x1="80" y1="35" x2="160" y2="35" stroke="#F5A623" stroke-width="1" opacity="0.2"/>
          <line x1="160" y1="35" x2="240" y2="35" stroke="#F5A623" stroke-width="1" opacity="0.2"/>
          <line x1="240" y1="35" x2="320" y2="35" stroke="#F5A623" stroke-width="1" opacity="0.2"/>
          <line x1="320" y1="35" x2="400" y2="35" stroke="#F5A623" stroke-width="1" opacity="0.2"/>
          <line x1="400" y1="35" x2="480" y2="35" stroke="#F5A623" stroke-width="1" opacity="0.2"/>
          <!-- Electron cloud -->
          <circle cx="300" cy="75" r="60" fill="none" stroke="#F5A623" stroke-width="0.5" opacity="0.15" stroke-dasharray="4 4">
            <animateTransform attributeName="transform" type="rotate" values="0 300 75;360 300 75" dur="20s" repeatCount="indefinite"/>
          </circle>
          <circle cx="300" cy="75" r="90" fill="none" stroke="#F5A623" stroke-width="0.5" opacity="0.1" stroke-dasharray="6 6">
            <animateTransform attributeName="transform" type="rotate" values="360 300 75;0 300 75" dur="25s" repeatCount="indefinite"/>
          </circle>
        </svg>
      </div>
      <h1>Aluminum Alloy Comparison</h1>
      <p class="header-sub">Select up to 3 alloys to compare properties side by side</p>
    </div>

    <!-- Series Overview Cards -->
    <div class="content-card reveal" style="margin-bottom: 30px;">
      <h2 class="section-heading">Alloy Series Overview</h2>
      <p class="section-desc">Click a series to filter alloys in the selectors below</p>
      <div class="series-grid" id="series-grid">
        <button class="series-card active" data-series="all" type="button">
          <div class="series-icon">
            <svg viewBox="0 0 48 48"><circle cx="24" cy="24" r="18" fill="none" stroke="#F5A623" stroke-width="2" opacity="0.4"/><circle cx="24" cy="24" r="10" fill="none" stroke="#F5A623" stroke-width="2" opacity="0.6"/><circle cx="24" cy="24" r="3" fill="#F5A623" opacity="0.8"><animate attributeName="r" values="3;5;3" dur="2s" repeatCount="indefinite"/></circle></svg>
          </div>
          <span class="series-name">All</span>
        </button>
        <button class="series-card" data-series="1xxx" type="button">
          <div class="series-icon">
            <svg viewBox="0 0 48 48"><rect x="10" y="10" width="28" height="28" rx="4" fill="none" stroke="#F5A623" stroke-width="2" opacity="0.5"/><text x="24" y="30" text-anchor="middle" fill="#F5A623" font-size="14" font-weight="600" font-family="var(--font-title)">Al</text><circle cx="24" cy="10" r="2" fill="#F5A623" opacity="0.6"><animate attributeName="cy" values="10;8;10" dur="2s" repeatCount="indefinite"/></circle></svg>
          </div>
          <span class="series-name">1xxx</span>
          <span class="series-label">Pure Al</span>
        </button>
        <button class="series-card" data-series="2xxx" type="button">
          <div class="series-icon">
            <svg viewBox="0 0 48 48"><circle cx="20" cy="24" r="10" fill="none" stroke="#F5A623" stroke-width="2" opacity="0.4"/><circle cx="30" cy="24" r="10" fill="none" stroke="#F5A623" stroke-width="2" opacity="0.6"/><circle cx="25" cy="24" r="3" fill="#F5A623" opacity="0.5"><animate attributeName="r" values="3;4;3" dur="1.8s" repeatCount="indefinite"/></circle></svg>
          </div>
          <span class="series-name">2xxx</span>
          <span class="series-label">Al-Cu</span>
        </button>
        <button class="series-card" data-series="3xxx" type="button">
          <div class="series-icon">
            <svg viewBox="0 0 48 48"><path d="M24 8 L38 36 L10 36 Z" fill="none" stroke="#F5A623" stroke-width="2" opacity="0.5"/><circle cx="24" cy="28" r="3" fill="#F5A623" opacity="0.6"><animate attributeName="opacity" values="0.6;1;0.6" dur="2s" repeatCount="indefinite"/></circle></svg>
          </div>
          <span class="series-name">3xxx</span>
          <span class="series-label">Al-Mn</span>
        </button>
        <button class="series-card" data-series="4xxx" type="button">
          <div class="series-icon">
            <svg viewBox="0 0 48 48"><polygon points="24,6 42,24 24,42 6,24" fill="none" stroke="#F5A623" stroke-width="2" opacity="0.5"/><circle cx="24" cy="24" r="4" fill="#F5A623" opacity="0.5"><animate attributeName="r" values="4;6;4" dur="2.2s" repeatCount="indefinite"/></circle></svg>
          </div>
          <span class="series-name">4xxx</span>
          <span class="series-label">Al-Si</span>
        </button>
        <button class="series-card" data-series="5xxx" type="button">
          <div class="series-icon">
            <svg viewBox="0 0 48 48"><path d="M24 6 L40 18 L36 38 L12 38 L8 18 Z" fill="none" stroke="#F5A623" stroke-width="2" opacity="0.5"/><circle cx="24" cy="24" r="3" fill="#F5A623" opacity="0.6"><animate attributeName="opacity" values="0.6;0.9;0.6" dur="1.5s" repeatCount="indefinite"/></circle></svg>
          </div>
          <span class="series-name">5xxx</span>
          <span class="series-label">Al-Mg</span>
        </button>
        <button class="series-card" data-series="6xxx" type="button">
          <div class="series-icon">
            <svg viewBox="0 0 48 48"><rect x="12" y="12" width="24" height="24" rx="6" fill="none" stroke="#F5A623" stroke-width="2" opacity="0.4"/><rect x="18" y="18" width="12" height="12" rx="3" fill="none" stroke="#F5A623" stroke-width="2" opacity="0.7"><animate attributeName="rx" values="3;6;3" dur="2s" repeatCount="indefinite"/></rect></svg>
          </div>
          <span class="series-name">6xxx</span>
          <span class="series-label">Al-Mg-Si</span>
        </button>
        <button class="series-card" data-series="7xxx" type="button">
          <div class="series-icon">
            <svg viewBox="0 0 48 48"><circle cx="24" cy="24" r="14" fill="none" stroke="#F5A623" stroke-width="2.5" opacity="0.5" stroke-dasharray="3 3"><animateTransform attributeName="transform" type="rotate" values="0 24 24;360 24 24" dur="8s" repeatCount="indefinite"/></circle><circle cx="24" cy="24" r="5" fill="#F5A623" opacity="0.7"><animate attributeName="r" values="5;7;5" dur="1.6s" repeatCount="indefinite"/></circle></svg>
          </div>
          <span class="series-name">7xxx</span>
          <span class="series-label">Al-Zn</span>
        </button>
      </div>
    </div>

    <!-- Alloy Selectors -->
    <div class="content-card reveal" style="margin-bottom: 30px;">
      <h2 class="section-heading">Select Alloys to Compare</h2>
      <div class="selectors-row">
        <div class="selector-col">
          <label class="selector-label">Alloy 1</label>
          <div class="custom-select" id="select-wrap-0">
            <button type="button" class="select-trigger" id="trigger-0">
              <span class="select-text" id="text-0">Choose alloy...</span>
              <svg class="select-arrow" width="12" height="12" viewBox="0 0 12 12"><path fill="#666" d="M6 8L1 3h10z"/></svg>
            </button>
            <div class="select-dropdown" id="dropdown-0">
              <input type="text" class="select-search" id="search-0" placeholder="Search alloy..." />
              <div class="select-options" id="options-0"></div>
            </div>
          </div>
        </div>
        <div class="selector-col">
          <label class="selector-label">Alloy 2</label>
          <div class="custom-select" id="select-wrap-1">
            <button type="button" class="select-trigger" id="trigger-1">
              <span class="select-text" id="text-1">Choose alloy...</span>
              <svg class="select-arrow" width="12" height="12" viewBox="0 0 12 12"><path fill="#666" d="M6 8L1 3h10z"/></svg>
            </button>
            <div class="select-dropdown" id="dropdown-1">
              <input type="text" class="select-search" id="search-1" placeholder="Search alloy..." />
              <div class="select-options" id="options-1"></div>
            </div>
          </div>
        </div>
        <div class="selector-col">
          <label class="selector-label">Alloy 3 <span class="optional-tag">(optional)</span></label>
          <div class="custom-select" id="select-wrap-2">
            <button type="button" class="select-trigger" id="trigger-2">
              <span class="select-text" id="text-2">Choose alloy...</span>
              <svg class="select-arrow" width="12" height="12" viewBox="0 0 12 12"><path fill="#666" d="M6 8L1 3h10z"/></svg>
            </button>
            <div class="select-dropdown" id="dropdown-2">
              <input type="text" class="select-search" id="search-2" placeholder="Search alloy..." />
              <div class="select-options" id="options-2"></div>
            </div>
          </div>
        </div>
      </div>
      <div class="selector-actions">
        <button type="button" class="btn-compare" id="btn-compare" disabled>Compare Alloys</button>
        <button type="button" class="btn-reset" id="btn-reset">Reset</button>
      </div>
    </div>

    <!-- Radar Chart -->
    <div class="content-card reveal" id="radar-section" style="margin-bottom: 30px; display: none;">
      <h2 class="section-heading">Property Radar Chart</h2>
      <div class="radar-container">
        <div class="radar-chart" id="radar-chart"></div>
        <div class="radar-legend" id="radar-legend"></div>
      </div>
    </div>

    <!-- Comparison Table -->
    <div class="content-card reveal" id="comparison-section" style="display: none;">
      <h2 class="section-heading">Detailed Comparison</h2>
      <div class="comparison-table-wrap">
        <table class="comparison-table" id="comparison-table">
          <thead id="table-head"></thead>
          <tbody id="table-body"></tbody>
        </table>
      </div>
    </div>

  </section>
</Layout>

<style>
  .alloy-page {
    padding: 100px 20px 60px;
  }

  .alloy-header {
    text-align: center;
    max-width: var(--max-width);
    margin: 0 auto 40px;
  }

  .header-illustration {
    max-width: 600px;
    margin: 0 auto 20px;
  }

  .lattice-svg {
    width: 100%;
    height: auto;
  }

  .alloy-header h1 {
    font-family: var(--font-title);
    font-size: 2.6rem;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 8px;
  }

  .header-sub {
    font-size: 1.1rem;
    color: var(--color-text-light);
    font-weight: 400;
  }

  .section-heading {
    font-family: var(--font-title);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 6px;
  }

  .section-desc {
    font-size: 0.92rem;
    color: var(--color-text-light);
    margin-bottom: 20px;
  }

  /* Series Grid */
  .series-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(95px, 1fr));
    gap: 12px;
    margin-top: 16px;
  }

  .series-card {
    background: rgba(255,255,255,0.65);
    border: 1px solid rgba(245,166,35,0.12);
    border-radius: 16px;
    padding: 14px 8px 12px;
    text-align: center;
    cursor: pointer;
    transition: all 0.35s cubic-bezier(0.25,0.46,0.45,0.94);
    font-family: var(--font-main);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .series-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(245,166,35,0.15);
    border-color: rgba(245,166,35,0.4);
    background: rgba(255,255,255,0.9);
  }

  .series-card.active {
    border-color: rgba(245,166,35,0.6);
    background: rgba(245,166,35,0.08);
    box-shadow: 0 0 20px rgba(245,166,35,0.15);
  }

  .series-icon {
    width: 48px;
    height: 48px;
  }

  .series-icon svg {
    width: 100%;
    height: 100%;
  }

  .series-name {
    font-family: var(--font-title);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .series-label {
    font-size: 0.72rem;
    color: var(--color-text-light);
    font-weight: 400;
  }

  /* Selectors */
  .selectors-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 20px;
  }

  .selector-col {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .selector-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .optional-tag {
    font-weight: 400;
    color: var(--color-text-light);
    font-size: 0.78rem;
  }

  .custom-select {
    position: relative;
  }

  .select-trigger {
    width: 100%;
    padding: 10px 14px;
    background: rgba(255,255,255,0.85);
    border: 1px solid rgba(245,166,35,0.2);
    border-radius: 12px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-main);
    font-size: 0.9rem;
    color: var(--color-text);
    transition: all 0.25s;
  }

  .select-trigger:hover {
    border-color: rgba(245,166,35,0.5);
  }

  .select-trigger.has-value {
    border-color: rgba(245,166,35,0.5);
    background: rgba(245,166,35,0.05);
  }

  .select-arrow {
    transition: transform 0.25s;
  }

  .custom-select.open .select-arrow {
    transform: rotate(180deg);
  }

  .select-dropdown {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    background: rgba(255,255,255,0.97);
    border: 1px solid rgba(245,166,35,0.25);
    border-radius: 12px;
    box-shadow: 0 12px 36px rgba(0,0,0,0.1);
    z-index: 50;
    display: none;
    overflow: hidden;
    backdrop-filter: blur(20px);
  }

  .custom-select.open .select-dropdown {
    display: block;
  }

  .select-search {
    width: 100%;
    padding: 10px 14px;
    border: none;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    font-family: var(--font-main);
    font-size: 0.85rem;
    outline: none;
    background: transparent;
  }

  .select-options {
    max-height: 220px;
    overflow-y: auto;
  }

  .select-option {
    padding: 8px 14px;
    cursor: pointer;
    font-size: 0.85rem;
    color: var(--color-text);
    transition: background 0.15s;
