---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Page Not Found | Far East Metals" description="The page you are looking for could not be found.">
  <section class="error-page">
    <div class="content-card error-card">
      <div class="error-number">404</div>
      <h1>Page Not Found</h1>
      <p class="error-description">
        The page you are looking for may have been moved, removed, or does not exist. Please check the URL or navigate back to the homepage.
      </p>
      <a href="/" class="home-button">Back to Homepage</a>
    </div>
  </section>
</Layout>

<style>
  .error-page {
    padding: 100px 20px 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 160px);
  }

  .error-card {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 40px;
    max-width: 560px;
    width: 100%;
  }

  .error-number {
    font-size: 8rem;
    font-weight: 700;
    font-family: var(--font-title);
    line-height: 1;
    margin-bottom: 16px;
    background: linear-gradient(135deg, var(--color-accent), #d4891a);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: error-pulse 3s ease-in-out infinite;
  }

  @keyframes error-pulse {
    0%, 100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.75;
      transform: scale(1.04);
    }
  }

  .error-card h1 {
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 12px;
  }

  .error-description {
    font-size: 0.95rem;
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: 32px;
    max-width: 420px;
  }

  .home-button {
    display: inline-block;
    padding: 14px 36px;
    background: linear-gradient(135deg, var(--color-accent), #d4891a);
    color: white;
    text-decoration: none;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    transition: all 0.3s;
    box-shadow: 0 4px 15px rgba(245, 166, 35, 0.2);
  }

  .home-button:hover {
    background: linear-gradient(135deg, #d4891a, #c07818);
    box-shadow: 0 6px 20px rgba(245, 166, 35, 0.3);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .error-card {
      padding: 40px 24px;
    }

    .error-number {
      font-size: 6rem;
    }

    .error-card h1 {
      font-size: 1.3rem;
    }

    .error-description {
      font-size: 0.9rem;
    }
  }
</style>
