---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Far East Metals Development Ltd. | Aluminum Profile | Forging | Ingot | Hong Kong">
  <section class="hero">
    <div class="hero-content">
      <h1 class="hero-title">Far East Metals Development</h1>
      <div class="hero-right">
        <h2 class="hero-aluminum">Aluminum</h2>
        <h2 class="hero-services">Extrusion | Forging | Ingot</h2>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    min-height: 100vh;
    padding: 0 20px;
  }

  .hero-content {
    max-width: var(--max-width);
    width: 100%;
    padding-top: 42%;
  }

  .hero-title {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: clamp(40px, 5.75vw, 87px);
    font-weight: 300;
    color: rgb(44, 50, 41);
    letter-spacing: normal;
    line-height: normal;
    margin-bottom: 0;
    text-align: center;
    white-space: nowrap;
  }

  .hero-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    padding-right: 0;
  }

  .hero-aluminum {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: clamp(24px, 2.7vw, 41px);
    font-weight: 300;
    color: rgb(39, 43, 49);
    letter-spacing: normal;
    line-height: normal;
    margin: 0;
  }

  .hero-services {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: clamp(13px, 1.52vw, 23px);
    font-weight: 300;
    color: rgb(39, 43, 49);
    letter-spacing: normal;
    line-height: normal;
    margin: 0;
  }

  @media (max-width: 768px) {
    .hero-content {
      padding-top: 30%;
    }

    .hero-title {
      white-space: normal;
      text-align: center;
    }
  }
</style>
