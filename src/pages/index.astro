---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Far East Metals Development Ltd. | Aluminum Profile | Forging | Ingot | Hong Kong">
  <!-- Hero Section -->
  <section class="hp-hero">
    <div class="hp-hero-content reveal">
      <h1 class="hp-hero-title">Far East Metals Development</h1>
      <div class="hp-hero-sub">
        <h2 class="hp-hero-aluminum">Aluminum</h2>
        <h2 class="hp-hero-services">Extrusion | Forging | Ingot</h2>
      </div>
      <div class="hp-hero-cta">
        <a href="/contact/" class="hp-btn-primary">Get a Quote</a>
        <a href="/about/" class="hp-btn-secondary">Learn More</a>
      </div>
    </div>
    <div class="hp-scroll-indicator">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M7 13l5 5 5-5M7 6l5 5 5-5"/></svg>
    </div>
  </section>

  <!-- Process Showcase - Horizontal Scroll -->
  <section class="hp-process">
    <div class="hp-container">
      <h2 class="hp-section-title reveal">Manufacturing Excellence</h2>
      <p class="hp-section-sub reveal reveal-delay-1">End-to-end aluminum solutions</p>
    </div>
    <div class="hp-process-track">
      <div class="hp-process-card reveal">
        <div class="hp-process-visual">
          <svg viewBox="0 0 200 160" class="hp-process-svg">
            <!-- Extrusion animation: billet pushed through die -->
            <rect x="20" y="50" width="60" height="60" rx="4" fill="#F5A623" opacity="0.15" stroke="#F5A623" stroke-width="1.5">
              <animate attributeName="width" values="60;35;60" dur="3s" repeatCount="indefinite"/>
              <animate attributeName="x" values="20;45;20" dur="3s" repeatCount="indefinite"/>
            </rect>
            <rect x="80" y="40" width="12" height="80" rx="2" fill="none" stroke="#F5A623" stroke-width="2"/>
            <rect x="84" y="60" width="4" height="40" fill="#F5A623" opacity="0.3"/>
            <line x1="92" y1="78" x2="180" y2="78" stroke="#F5A623" stroke-width="6" stroke-linecap="round" opacity="0.6">
              <animate attributeName="x2" values="140;180;140" dur="3s" repeatCount="indefinite"/>
            </line>
            <line x1="92" y1="82" x2="180" y2="82" stroke="#F5A623" stroke-width="6" stroke-linecap="round" opacity="0.4">
              <animate attributeName="x2" values="140;180;140" dur="3s" repeatCount="indefinite"/>
            </line>
          </svg>
        </div>
        <h3>Extrusion</h3>
        <p>Custom aluminum profiles</p>
      </div>

      <div class="hp-process-card reveal reveal-delay-1">
        <div class="hp-process-visual">
          <svg viewBox="0 0 200 160" class="hp-process-svg">
            <!-- Forging animation: hammer striking -->
            <rect x="70" y="100" width="60" height="20" rx="3" fill="#F5A623" opacity="0.2" stroke="#F5A623" stroke-width="1.5"/>
            <path d="M85 100 Q100 80 115 100" fill="#F5A623" opacity="0.3" stroke="#F5A623" stroke-width="1.5">
              <animate attributeName="d" values="M85 100 Q100 80 115 100;M85 100 Q100 88 115 100;M85 100 Q100 80 115 100" dur="1.5s" repeatCount="indefinite"/>
            </path>
            <rect x="85" y="30" width="30" height="40" rx="3" fill="none" stroke="#F5A623" stroke-width="2">
              <animate attributeName="y" values="30;55;30" dur="1.5s" repeatCount="indefinite"/>
              <animate attributeName="height" values="40;40;40" dur="1.5s" repeatCount="indefinite"/>
            </rect>
            <line x1="100" y1="15" x2="100" y2="30" stroke="#F5A623" stroke-width="3" stroke-linecap="round">
              <animate attributeName="y2" values="30;55;30" dur="1.5s" repeatCount="indefinite"/>
            </line>
            <!-- Impact sparks -->
            <circle cx="75" cy="95" r="2" fill="#F5A623" opacity="0">
              <animate attributeName="opacity" values="0;0.8;0" dur="1.5s" repeatCount="indefinite" begin="0.4s"/>
              <animate attributeName="cx" values="80;70;80" dur="1.5s" repeatCount="indefinite" begin="0.4s"/>
              <animate attributeName="cy" values="95;85;95" dur="1.5s" repeatCount="indefinite" begin="0.4s"/>
            </circle>
            <circle cx="125" cy="95" r="2" fill="#F5A623" opacity="0">
              <animate attributeName="opacity" values="0;0.8;0" dur="1.5s" repeatCount="indefinite" begin="0.5s"/>
              <animate attributeName="cx" values="120;130;120" dur="1.5s" repeatCount="indefinite" begin="0.5s"/>
              <animate attributeName="cy" values="95;85;95" dur="1.5s" repeatCount="indefinite" begin="0.5s"/>
            </circle>
          </svg>
        </div>
        <h3>Forging</h3>
        <p>High-strength components</p>
      </div>

      <div class="hp-process-card reveal reveal-delay-2">
        <div class="hp-process-visual">
          <svg viewBox="0 0 200 160" class="hp-process-svg">
            <!-- Rolling animation: rollers with sheet -->
            <circle cx="80" cy="65" r="20" fill="none" stroke="#F5A623" stroke-width="2">
              <animateTransform attributeName="transform" type="rotate" from="0 80 65" to="360 80 65" dur="2s" repeatCount="indefinite"/>
            </circle>
            <circle cx="120" cy="65" r="20" fill="none" stroke="#F5A623" stroke-width="2">
              <animateTransform attributeName="transform" type="rotate" from="360 120 65" to="0 120 65" dur="2s" repeatCount="indefinite"/>
            </circle>
            <line x1="80" y1="55" x2="80" y2="75" stroke="#F5A623" stroke-width="1" opacity="0.3"/>
            <line x1="120" y1="55" x2="120" y2="75" stroke="#F5A623" stroke-width="1" opacity="0.3"/>
            <!-- Sheet entering -->
            <rect x="20" y="75" width="60" height="12" rx="2" fill="#F5A623" opacity="0.2" stroke="#F5A623" stroke-width="1">
              <animate attributeName="x" values="15;25;15" dur="2s" repeatCount="indefinite"/>
            </rect>
            <!-- Sheet exiting (thinner) -->
            <rect x="120" y="78" width="65" height="6" rx="1" fill="#F5A623" opacity="0.3" stroke="#F5A623" stroke-width="1">
              <animate attributeName="width" values="60;70;60" dur="2s" repeatCount="indefinite"/>
            </rect>
            <circle cx="80" cy="65" r="3" fill="#F5A623" opacity="0.5"/>
            <circle cx="120" cy="65" r="3" fill="#F5A623" opacity="0.5"/>
          </svg>
        </div>
        <h3>Rolling</h3>
        <p>Sheets, plates & coils</p>
      </div>

      <div class="hp-process-card reveal reveal-delay-3">
        <div class="hp-process-visual">
          <svg viewBox="0 0 200 160" class="hp-process-svg">
            <!-- Die casting: molten metal pouring into mold -->
            <rect x="60" y="70" width="80" height="50" rx="4" fill="none" stroke="#F5A623" stroke-width="2"/>
            <path d="M75 70 L75 90 Q100 110 125 90 L125 70" fill="#F5A623" opacity="0.15" stroke="none"/>
            <!-- Mold cavity shape -->
            <path d="M80 85 L90 75 L110 75 L120 85 L120 105 L80 105 Z" fill="none" stroke="#F5A623" stroke-width="1" stroke-dasharray="3 2" opacity="0.5"/>
            <!-- Pouring stream -->
            <line x1="100" y1="20" x2="100" y2="70" stroke="#F5A623" stroke-width="4" stroke-linecap="round" opacity="0.5">
              <animate attributeName="opacity" values="0.3;0.7;0.3" dur="2s" repeatCount="indefinite"/>
            </line>
            <!-- Ladle -->
            <path d="M85 20 Q100 10 115 20 L112 28 Q100 22 88 28 Z" fill="#F5A623" opacity="0.3" stroke="#F5A623" stroke-width="1.5"/>
            <!-- Fill level rising -->
            <rect x="81" y="105" width="38" height="0" fill="#F5A623" opacity="0.2">
              <animate attributeName="height" values="0;20;0" dur="3s" repeatCount="indefinite"/>
              <animate attributeName="y" values="105;85;105" dur="3s" repeatCount="indefinite"/>
            </rect>
          </svg>
        </div>
        <h3>Die Casting</h3>
        <p>Complex precision parts</p>
      </div>

      <div class="hp-process-card reveal reveal-delay-3">
        <div class="hp-process-visual">
          <svg viewBox="0 0 200 160" class="hp-process-svg">
            <!-- Surface treatment: anodizing tank -->
            <rect x="40" y="60" width="120" height="70" rx="4" fill="none" stroke="#F5A623" stroke-width="2"/>
            <!-- Liquid -->
            <rect x="42" y="80" width="116" height="48" rx="2" fill="#F5A623" opacity="0.1"/>
            <!-- Workpiece dipping -->
            <rect x="90" y="40" width="20" height="60" rx="2" fill="none" stroke="#F5A623" stroke-width="2">
              <animate attributeName="y" values="40;55;40" dur="3s" repeatCount="indefinite"/>
            </rect>
            <!-- Bubbles -->
            <circle cx="65" cy="110" r="3" fill="#F5A623" opacity="0">
              <animate attributeName="cy" values="120;80;120" dur="2s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0;0.5;0" dur="2s" repeatCount="indefinite"/>
            </circle>
            <circle cx="100" cy="115" r="2" fill="#F5A623" opacity="0">
              <animate attributeName="cy" values="120;85;120" dur="2.5s" repeatCount="indefinite" begin="0.3s"/>
              <animate attributeName="opacity" values="0;0.4;0" dur="2.5s" repeatCount="indefinite" begin="0.3s"/>
            </circle>
            <circle cx="135" cy="112" r="2.5" fill="#F5A623" opacity="0">
              <animate attributeName="cy" values="120;82;120" dur="1.8s" repeatCount="indefinite" begin="0.6s"/>
              <animate attributeName="opacity" values="0;0.5;0" dur="1.8s" repeatCount="indefinite" begin="0.6s"/>
            </circle>
            <!-- Wire -->
            <line x1="100" y1="20" x2="100" y2="40" stroke="#F5A623" stroke-width="1.5">
              <animate attributeName="y2" values="40;55;40" dur="3s" repeatCount="indefinite"/>
            </line>
          </svg>
        </div>
        <h3>Surface Treatment</h3>
        <p>Anodizing & finishing</p>
      </div>

      <div class="hp-process-card reveal reveal-delay-3">
        <div class="hp-process-visual">
          <svg viewBox="0 0 200 160" class="hp-process-svg">
            <!-- Heat treatment: furnace -->
            <rect x="40" y="50" width="120" height="80" rx="6" fill="none" stroke="#F5A623" stroke-width="2"/>
            <rect x="50" y="60" width="100" height="60" rx="3" fill="#F5A623" opacity="0.08"/>
            <!-- Heat waves -->
            <path d="M70 100 Q80 90 90 100 Q100 110 110 100 Q120 90 130 100" fill="none" stroke="#F5A623" stroke-width="1.5" opacity="0.4">
              <animate attributeName="d" values="M70 100 Q80 90 90 100 Q100 110 110 100 Q120 90 130 100;M70 95 Q80 105 90 95 Q100 85 110 95 Q120 105 130 95;M70 100 Q80 90 90 100 Q100 110 110 100 Q120 90 130 100" dur="2s" repeatCount="indefinite"/>
            </path>
            <path d="M70 85 Q80 75 90 85 Q100 95 110 85 Q120 75 130 85" fill="none" stroke="#F5A623" stroke-width="1.5" opacity="0.3">
              <animate attributeName="d" values="M70 85 Q80 75 90 85 Q100 95 110 85 Q120 75 130 85;M70 80 Q80 90 90 80 Q100 70 110 80 Q120 90 130 80;M70 85 Q80 75 90 85 Q100 95 110 85 Q120 75 130 85" dur="2.5s" repeatCount="indefinite"/>
            </path>
            <!-- Temperature glow -->
            <circle cx="100" cy="90" r="15" fill="#F5A623" opacity="0.1">
              <animate attributeName="r" values="12;18;12" dur="2s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0.05;0.15;0.05" dur="2s" repeatCount="indefinite"/>
            </circle>
            <!-- Thermometer -->
            <rect x="155" y="55" width="6" height="40" rx="3" fill="none" stroke="#F5A623" stroke-width="1.5"/>
            <rect x="156" y="75" width="4" height="18" rx="2" fill="#F5A623" opacity="0.5">
              <animate attributeName="height" values="12;20;12" dur="3s" repeatCount="indefinite"/>
              <animate attributeName="y" values="81;73;81" dur="3s" repeatCount="indefinite"/>
            </rect>
          </svg>
        </div>
        <h3>Heat Treatment</h3>
        <p>T5, T6 & annealing</p>
      </div>
    </div>
  </section>

  <!-- Stats Band -->
  <section class="hp-stats-band">
    <div class="hp-container">
      <div class="hp-stats-row">
        <div class="hp-stat reveal">
          <span class="hp-stat-num" data-target="20">0</span><span class="hp-stat-plus">+</span>
          <span class="hp-stat-label">Years</span>
        </div>
        <div class="hp-stat-divider"></div>
        <div class="hp-stat reveal reveal-delay-1">
          <span class="hp-stat-num" data-target="100">0</span><span class="hp-stat-plus">+</span>
          <span class="hp-stat-label">Factories</span>
        </div>
        <div class="hp-stat-divider"></div>
        <div class="hp-stat reveal reveal-delay-2">
          <span class="hp-stat-num" data-target="30">0</span><span class="hp-stat-plus">+</span>
          <span class="hp-stat-label">Countries</span>
        </div>
        <div class="hp-stat-divider"></div>
        <div class="hp-stat reveal reveal-delay-3">
          <span class="hp-stat-num" data-target="8">0</span><span class="hp-stat-plus"></span>
          <span class="hp-stat-label">Processes</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="hp-industries">
    <div class="hp-container">
      <h2 class="hp-section-title reveal">Industries We Serve</h2>
      <p class="hp-section-sub reveal reveal-delay-1">Trusted across sectors worldwide</p>
      <div class="hp-ind-grid">
        <div class="hp-ind-card reveal">
          <div class="hp-ind-icon">
            <svg viewBox="0 0 48 48" width="36" height="36"><path d="M24 4L4 20h6v20h28V20h6L24 4z" fill="none" stroke="currentColor" stroke-width="2"/><rect x="18" y="28" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"/></svg>
          </div>
          <span>Architecture</span>
        </div>
        <div class="hp-ind-card reveal reveal-delay-1">
          <div class="hp-ind-icon">
            <svg viewBox="0 0 48 48" width="36" height="36"><rect x="8" y="18" width="32" height="16" rx="8" fill="none" stroke="currentColor" stroke-width="2"/><circle cx="16" cy="34" r="5" fill="none" stroke="currentColor" stroke-width="2"/><circle cx="32" cy="34" r="5" fill="none" stroke="currentColor" stroke-width="2"/></svg>
          </div>
          <span>Automotive</span>
        </div>
        <div class="hp-ind-card reveal reveal-delay-2">
          <div class="hp-ind-icon">
            <svg viewBox="0 0 48 48" width="36" height="36"><path d="M8 38L20 8h8l12 30" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="12" y1="28" x2="36" y2="28" stroke="currentColor" stroke-width="2"/></svg>
          </div>
          <span>Aerospace</span>
        </div>
        <div class="hp-ind-card reveal reveal-delay-3">
          <div class="hp-ind-icon">
            <svg viewBox="0 0 48 48" width="36" height="36"><rect x="10" y="6" width="28" height="36" rx="3" fill="none" stroke="currentColor" stroke-width="2"/><rect x="14" y="10" width="20" height="14" rx="1" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="24" cy="34" r="3" fill="none" stroke="currentColor" stroke-width="2"/></svg>
          </div>
          <span>Electronics</span>
        </div>
        <div class="hp-ind-card reveal">
          <div class="hp-ind-icon">
            <svg viewBox="0 0 48 48" width="36" height="36"><circle cx="24" cy="24" r="10" fill="none" stroke="currentColor" stroke-width="2"/><path d="M24 14V8M24 40v-6M34 24h6M8 24h6" stroke="currentColor" stroke-width="2"/><circle cx="24" cy="24" r="3" fill="currentColor" opacity="0.3"/></svg>
          </div>
          <span>Machinery</span>
        </div>
        <div class="hp-ind-card reveal reveal-delay-1">
          <div class="hp-ind-icon">
            <svg viewBox="0 0 48 48" width="36" height="36"><path d="M4 40h40M12 40V20l12-8 12 8v20" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><rect x="20" y="28" width="8" height="12" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
          </div>
          <span>Construction</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="hp-cta">
    <div class="hp-cta-card reveal">
        <h2>Ready to Start Your Project?</h2>
        <p>Free consultation. Competitive pricing. Global delivery.</p>
        <div class="hp-cta-buttons">
          <a href="/contact/" class="hp-btn-primary hp-btn-lg">Contact Us</a>
          <a href="/brochure.pdf" class="hp-btn-outline hp-btn-lg" download="Far_East_Metals_Brochure.pdf">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download Brochure
          </a>
        </div>
      </div>
  </section>
</Layout>

<style is:global>
  /* Hero */
  .hp-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 0 20px;
    position: relative;
  }

  .hp-hero-content {
    max-width: var(--max-width);
    width: 100%;
    padding-top: 15vh;
    text-align: center;
  }

  .hp-hero-title {
    font-family: var(--font-title);
    font-size: clamp(40px, 5.75vw, 87px);
    font-weight: 500;
    color: #fff;
    line-height: 1.1;
    margin-bottom: 5px;
    white-space: nowrap;
  }

  .hp-hero-sub {
    text-align: center;
    margin-bottom: 35px;
  }

  .hp-hero-aluminum {
    font-family: var(--font-main);
    font-size: clamp(24px, 2.7vw, 41px);
    font-weight: 300;
    color: #fff;
    line-height: 1.2;
    margin: 0;
  }

  .hp-hero-services {
    font-family: var(--font-main);
    font-size: clamp(13px, 1.52vw, 23px);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.2;
    margin: 0;
  }

  .hp-hero-cta {
    display: flex;
    gap: 16px;
    justify-content: center;
  }

  /* Buttons */
  .hp-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: var(--color-accent);
    color: white;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.3s;
    border: none;
    cursor: pointer;
  }

  .hp-btn-primary:hover {
    background: #d4891a;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(245, 166, 35, 0.35);
  }

  .hp-btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: rgba(255, 255, 255, 0.15);
    color: white;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 500;
    font-size: 1rem;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.25);
    transition: all 0.3s;
  }

  .hp-btn-secondary:hover {
    background: rgba(255, 255, 255, 0.25);
    transform: translateY(-2px);
  }

  .hp-btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: transparent;
    color: white;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 500;
    font-size: 1rem;
    border: 2px solid rgba(255, 255, 255, 0.6);
    transition: all 0.3s;
  }

  .hp-btn-outline:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: white;
    transform: translateY(-2px);
  }

  .hp-btn-lg {
    padding: 16px 36px;
    font-size: 1.05rem;
  }

  .hp-scroll-indicator {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    animation: hp-bounce 2s infinite;
    opacity: 0.6;
  }

  @keyframes hp-bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(10px); }
  }

  /* Container */
  .hp-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Section Titles */
  .hp-section-title {
    font-family: var(--font-title);
    font-size: clamp(28px, 3vw, 40px);
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 8px;
  }

  .hp-section-sub {
    color: var(--color-text-light);
    font-size: 1rem;
    margin-bottom: 35px;
  }

  /* ===== Glowing Section Card Base ===== */
  .hp-process,
  .hp-industries {
    position: relative;
  }

  .hp-process::before,
  .hp-industries::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 22px;
    padding: 1.5px;
    background: linear-gradient(
      135deg,
      rgba(245, 166, 35, 0.5),
      rgba(255, 255, 255, 0.1) 30%,
      rgba(255, 255, 255, 0.05) 50%,
      rgba(255, 255, 255, 0.1) 70%,
      rgba(245, 166, 35, 0.3)
    );
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    transition: opacity 0.5s;
    opacity: 0.7;
  }

  .hp-process:hover::before,
  .hp-industries:hover::before {
    opacity: 1;
    background: linear-gradient(
      135deg,
      rgba(245, 166, 35, 0.8),
      rgba(255, 200, 100, 0.2) 30%,
      rgba(255, 255, 255, 0.1) 50%,
      rgba(255, 200, 100, 0.2) 70%,
      rgba(245, 166, 35, 0.6)
    );
  }

  /* ===== Process Showcase ===== */
  .hp-process {
    padding: 80px 0 60px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 22px;
    margin: -40px 15px 0;
    z-index: 2;
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    text-align: center;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.06), inset 0 1px 0 rgba(255, 255, 255, 0.15);
    transition: box-shadow 0.4s;
  }

  .hp-process:hover {
