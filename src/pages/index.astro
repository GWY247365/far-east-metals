---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Far East Metals Development Ltd. | Aluminum Profile | Forging | Ingot | Hong Kong">
  <section class="hero">
    <div class="hero-content">
      <h1 class="hero-title">Far East Metals Development</h1>
      <h2 class="hero-aluminum">Aluminum</h2>
      <h2 class="hero-services">Extrusion | Forging | Ingot</h2>
    </div>
  </section>
</Layout>

<style>
  .hero {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    min-height: 100vh;
    padding: 0 20px;
    padding-top: 28vh;
  }

  .hero-content {
    max-width: var(--max-width);
    width: 100%;
    text-align: center;
  }

  .hero-title {
    font-size: 87px;
    font-weight: 400;
    color: rgb(44, 50, 41);
    letter-spacing: normal;
    margin-bottom: 0;
    text-shadow: none;
  }

  .hero-aluminum {
    font-size: 41px;
    font-weight: 400;
    color: rgb(39, 43, 49);
    text-align: center;
    margin-bottom: 0;
    margin-top: 0;
  }

  .hero-services {
    font-size: 23px;
    font-weight: 400;
    color: rgb(39, 43, 49);
    text-align: right;
    margin-top: -2px;
    padding-right: 5%;
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: 20vh;
    }

    .hero-title {
      font-size: 40px;
    }

    .hero-aluminum {
      font-size: 24px;
    }

    .hero-services {
      font-size: 14px;
    }
  }
</style>
