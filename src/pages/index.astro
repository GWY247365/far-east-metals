---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Far East Metals Development Ltd. | Aluminum Profile | Forging | Ingot | Hong Kong">
  <!-- Hero Section -->
  <section class="hp-hero">
    <div class="hp-hero-content reveal">
      <h1 class="hp-hero-title">Far East Metals Development</h1>
      <div class="hp-hero-sub">
        <h2 class="hp-hero-aluminum">Aluminum</h2>
        <h2 class="hp-hero-services">Extrusion | Forging | Ingot</h2>
      </div>
      <div class="hp-hero-cta">
        <a href="/contact/" class="hp-btn-primary">Get a Quote</a>
        <a href="/about/" class="hp-btn-secondary">Learn More</a>
      </div>
    </div>
    <div class="hp-scroll-indicator">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M7 13l5 5 5-5M7 6l5 5 5-5"/></svg>
    </div>
  </section>

  <!-- Services Highlights -->
  <section class="hp-services">
    <div class="hp-container">
      <h2 class="hp-section-title reveal">What We Do</h2>
      <p class="hp-section-sub reveal reveal-delay-1">Comprehensive aluminum solutions from raw material to finished product</p>
      <div class="hp-services-grid">
        <div class="hp-svc-card reveal">
          <div class="hp-svc-icon">
            <svg viewBox="0 0 64 64" width="48" height="48">
              <rect x="8" y="28" width="20" height="16" rx="2" fill="var(--color-accent)" opacity="0.2" stroke="var(--color-accent)" stroke-width="1.5"/>
              <rect x="28" y="24" width="8" height="24" rx="1" fill="none" stroke="var(--color-accent)" stroke-width="1.5"/>
              <line x1="36" y1="36" x2="58" y2="36" stroke="var(--color-accent)" stroke-width="3" stroke-linecap="round">
                <animate attributeName="x1" values="36;42;36" dur="2s" repeatCount="indefinite"/>
              </line>
            </svg>
          </div>
          <h3>Aluminum Extrusion</h3>
          <p>Custom profiles for architecture, electronics, automotive, and industrial applications.</p>
        </div>
        <div class="hp-svc-card reveal reveal-delay-1">
          <div class="hp-svc-icon">
            <svg viewBox="0 0 64 64" width="48" height="48">
              <path d="M22 48 L32 22 L42 48 Z" fill="var(--color-accent)" opacity="0.2" stroke="var(--color-accent)" stroke-width="1.5" stroke-linejoin="round"/>
              <line x1="32" y1="12" x2="32" y2="24" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round">
                <animate attributeName="y2" values="22;26;22" dur="1.2s" repeatCount="indefinite"/>
              </line>
              <rect x="28" y="8" width="8" height="6" rx="1" fill="none" stroke="var(--color-accent)" stroke-width="1.5"/>
            </svg>
          </div>
          <h3>Precision Forging</h3>
          <p>High-strength forged components with superior grain structure for demanding applications.</p>
        </div>
        <div class="hp-svc-card reveal reveal-delay-2">
          <div class="hp-svc-icon">
            <svg viewBox="0 0 64 64" width="48" height="48">
              <rect x="12" y="28" width="40" height="12" rx="3" fill="var(--color-accent)" opacity="0.2" stroke="var(--color-accent)" stroke-width="1.5"/>
              <circle cx="22" cy="34" r="4" fill="none" stroke="var(--color-accent)" stroke-width="1.5">
                <animateTransform attributeName="transform" type="rotate" from="0 22 34" to="360 22 34" dur="3s" repeatCount="indefinite"/>
              </circle>
              <circle cx="42" cy="34" r="4" fill="none" stroke="var(--color-accent)" stroke-width="1.5">
                <animateTransform attributeName="transform" type="rotate" from="360 42 34" to="0 42 34" dur="3s" repeatCount="indefinite"/>
              </circle>
            </svg>
          </div>
          <h3>Flat Rolling</h3>
          <p>Aluminum sheets and plates in various alloys and tempers for diverse applications.</p>
        </div>
        <div class="hp-svc-card reveal reveal-delay-3">
          <div class="hp-svc-icon">
            <svg viewBox="0 0 64 64" width="48" height="48">
              <rect x="16" y="16" width="32" height="32" rx="3" fill="var(--color-accent)" opacity="0.2" stroke="var(--color-accent)" stroke-width="1.5"/>
              <path d="M26 38 L32 26 L38 38" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <animate attributeName="d" values="M26 38 L32 26 L38 38;M26 36 L32 28 L38 36;M26 38 L32 26 L38 38" dur="1.5s" repeatCount="indefinite"/>
              </path>
            </svg>
          </div>
          <h3>Die Casting</h3>
          <p>Complex aluminum parts with excellent surface finish and dimensional accuracy.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Preview -->
  <section class="hp-about">
    <div class="hp-container">
      <div class="hp-about-grid">
        <div class="hp-about-text reveal">
          <h2 class="hp-section-title">Industry Leader Since 2003</h2>
          <p>Far East Metals Development Limited stands as a prominent industry leader headquartered in Hong Kong, specializing in aluminum extrusion, forging, and ingot production.</p>
          <p>With a network of <strong>100+ partner factories</strong> and serving <strong>30+ countries</strong>, we bridge Chinese manufacturing excellence with global demand.</p>
          <a href="/about/" class="hp-link-arrow">
            Read our story
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-7-7l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="hp-about-stats reveal reveal-delay-1">
          <div class="hp-stat-card">
            <span class="hp-stat-num" data-target="20">0</span><span class="hp-stat-plus">+</span>
            <span class="hp-stat-label">Years Experience</span>
          </div>
          <div class="hp-stat-card">
            <span class="hp-stat-num" data-target="100">0</span><span class="hp-stat-plus">+</span>
            <span class="hp-stat-label">Partner Factories</span>
          </div>
          <div class="hp-stat-card">
            <span class="hp-stat-num" data-target="30">0</span><span class="hp-stat-plus">+</span>
            <span class="hp-stat-label">Countries Served</span>
          </div>
          <div class="hp-stat-card">
            <span class="hp-stat-num" data-target="8">0</span><span class="hp-stat-plus"></span>
            <span class="hp-stat-label">Core Processes</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tools Section -->
  <section class="hp-tools">
    <div class="hp-container">
      <h2 class="hp-section-title reveal">Professional Tools</h2>
      <p class="hp-section-sub reveal reveal-delay-1">Free resources to help you make better decisions</p>
      <a href="/metweighcalculator/" class="hp-tool-card reveal">
        <div class="hp-tool-icon">
          <svg viewBox="0 0 64 64" width="40" height="40">
            <rect x="14" y="10" width="36" height="44" rx="4" fill="none" stroke="var(--color-accent)" stroke-width="2"/>
            <rect x="18" y="14" width="28" height="10" rx="2" fill="var(--color-accent)" opacity="0.2"/>
            <circle cx="24" cy="32" r="3" fill="var(--color-accent)" opacity="0.4"/>
            <circle cx="32" cy="32" r="3" fill="var(--color-accent)" opacity="0.4"/>
            <circle cx="40" cy="32" r="3" fill="var(--color-accent)" opacity="0.4"/>
            <circle cx="24" cy="40" r="3" fill="var(--color-accent)" opacity="0.4"/>
            <circle cx="32" cy="40" r="3" fill="var(--color-accent)" opacity="0.4"/>
            <circle cx="40" cy="40" r="3" fill="var(--color-accent)" opacity="0.4"/>
          </svg>
        </div>
        <div class="hp-tool-content">
          <h3>Metal Weight Calculator</h3>
          <p>Calculate the weight of aluminum and other metals by shape, dimensions, and alloy grade.</p>
        </div>
        <svg class="hp-tool-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-7-7l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="hp-cta">
    <div class="hp-container">
      <div class="hp-cta-card reveal">
        <h2>Ready to Start Your Project?</h2>
        <p>Get in touch with our team for a free consultation and competitive quote.</p>
        <div class="hp-cta-buttons">
          <a href="/contact/" class="hp-btn-primary hp-btn-lg">Contact Us</a>
          <a href="/brochure.pdf" class="hp-btn-outline hp-btn-lg" download="Far_East_Metals_Brochure.pdf">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download Brochure
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  /* Hero */
  .hp-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 0 20px;
    position: relative;
  }

  .hp-hero-content {
    max-width: var(--max-width);
    width: 100%;
    padding-top: 15vh;
    text-align: center;
  }

  .hp-hero-title {
    font-family: var(--font-title);
    font-size: clamp(40px, 5.75vw, 87px);
    font-weight: 500;
    color: #fff;
    line-height: 1.1;
    margin-bottom: 5px;
    white-space: nowrap;
  }

  .hp-hero-sub {
    text-align: center;
    margin-bottom: 35px;
  }

  .hp-hero-aluminum {
    font-family: var(--font-main);
    font-size: clamp(24px, 2.7vw, 41px);
    font-weight: 300;
    color: #fff;
    line-height: 1.2;
    margin: 0;
  }

  .hp-hero-services {
    font-family: var(--font-main);
    font-size: clamp(13px, 1.52vw, 23px);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.2;
    margin: 0;
  }

  .hp-hero-cta {
    display: flex;
    gap: 16px;
    justify-content: center;
  }

  /* Buttons */
  .hp-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: var(--color-accent);
    color: white;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.3s;
    border: none;
    cursor: pointer;
  }

  .hp-btn-primary:hover {
    background: #d4891a;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(245, 166, 35, 0.35);
  }

  .hp-btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: rgba(255, 255, 255, 0.15);
    color: white;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 500;
    font-size: 1rem;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.25);
    transition: all 0.3s;
  }

  .hp-btn-secondary:hover {
    background: rgba(255, 255, 255, 0.25);
    transform: translateY(-2px);
  }

  .hp-btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 32px;
    background: transparent;
    color: white;
    text-decoration: none;
    border-radius: 8px;
    font-weight: 500;
    font-size: 1rem;
    border: 2px solid rgba(255, 255, 255, 0.6);
    transition: all 0.3s;
  }

  .hp-btn-outline:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: white;
    transform: translateY(-2px);
  }

  .hp-btn-lg {
    padding: 16px 36px;
    font-size: 1.05rem;
  }

  .hp-scroll-indicator {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    animation: hp-bounce 2s infinite;
    opacity: 0.6;
  }

  @keyframes hp-bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(10px); }
  }

  /* Container */
  .hp-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Section Titles */
  .hp-section-title {
    font-family: var(--font-title);
    font-size: clamp(28px, 3vw, 40px);
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 8px;
  }

  .hp-section-sub {
    color: var(--color-text-light);
    font-size: 1rem;
    margin-bottom: 35px;
  }

  /* Services Section */
  .hp-services {
    padding: 80px 0;
    background: var(--color-bg-card);
    border-radius: 20px;
    margin: -40px 15px 0;
    position: relative;
    z-index: 2;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    text-align: center;
  }

  .hp-services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .hp-svc-card {
    background: var(--color-bg-card-inner);
    border-radius: 12px;
    padding: 30px 20px;
    text-align: center;
    border: 1px solid rgba(200, 200, 200, 0.3);
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .hp-svc-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
  }

  .hp-svc-icon {
    margin-bottom: 16px;
  }

  .hp-svc-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: var(--color-text);
  }

  .hp-svc-card p {
    font-size: 0.85rem;
    color: var(--color-text-light);
    line-height: 1.6;
  }

  /* About Preview */
  .hp-about {
    padding: 80px 0;
    background: var(--color-bg-card);
    border-radius: 20px;
    margin: 20px 15px 0;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .hp-about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 50px;
    align-items: center;
  }

  .hp-about-text {
    background: var(--color-bg-card);
    padding: 40px;
    border-radius: 16px;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .hp-about-text .hp-section-title {
    text-align: left;
  }

  .hp-about-text p {
    margin-bottom: 16px;
    line-height: 1.7;
  }

  .hp-about-text strong {
    color: var(--color-accent);
    font-weight: 600;
  }

  .hp-link-arrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: gap 0.3s;
  }

  .hp-link-arrow:hover {
    gap: 12px;
  }

  .hp-about-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .hp-stat-card {
    background: var(--color-bg-card);
    border-radius: 14px;
    padding: 28px 20px;
    text-align: center;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(200, 200, 200, 0.2);
  }

  .hp-stat-num {
    font-family: var(--font-title);
    font-size: 2.6rem;
    font-weight: 600;
    color: var(--color-accent);
    line-height: 1;
  }

  .hp-stat-plus {
    font-family: var(--font-title);
    font-size: 2.6rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .hp-stat-label {
    display: block;
    font-size: 0.82rem;
    color: var(--color-text-light);
    margin-top: 6px;
  }

  /* Tools Section */
  .hp-tools {
    padding: 60px 0;
    text-align: center;
    background: var(--color-bg-card);
    border-radius: 20px;
    margin: 20px 15px 0;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .hp-tool-card {
    display: flex;
    align-items: center;
    gap: 20px;
    max-width: 600px;
    margin: 0 auto;
    background: var(--color-bg-card);
    border-radius: 14px;
    padding: 24px 30px;
    text-decoration: none;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(200, 200, 200, 0.2);
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .hp-tool-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
  }

  .hp-tool-icon {
    flex-shrink: 0;
  }

  .hp-tool-content {
    text-align: left;
    flex: 1;
  }

  .hp-tool-content h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 4px;
  }

  .hp-tool-content p {
    font-size: 0.85rem;
    color: var(--color-text-light);
    line-height: 1.5;
  }

  .hp-tool-arrow {
    flex-shrink: 0;
    color: var(--color-accent);
    transition: transform 0.3s;
  }

  .hp-tool-card:hover .hp-tool-arrow {
    transform: translateX(4px);
  }

  /* CTA Section */
  .hp-cta {
    padding: 40px 15px 80px;
    margin-top: 20px;
  }

  .hp-cta-card {
    background: linear-gradient(135deg, var(--color-accent), #d4891a);
    border-radius: 20px;
    padding: 60px 40px;
    text-align: center;
  }

  .hp-cta-card h2 {
    font-family: var(--font-title);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 500;
    margin-bottom: 12px;
    color: white;
  }

  .hp-cta-card p {
    font-size: 1.05rem;
    opacity: 0.9;
    margin-bottom: 30px;
    color: white;
  }

  .hp-cta-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hp-hero-content {
      padding-top: 18vh;
    }

    .hp-hero-title {
      white-space: normal;
      font-size: clamp(32px, 10vw, 50px);
    }

    .hp-hero-cta {
      flex-direction: column;
      align-items: center;
      gap: 12px;
    }

    .hp-hero-cta a {
      width: 100%;
      max-width: 260px;
      justify-content: center;
    }

    .hp-services {
      margin: -30px 10px 0;
      padding: 50px 15px;
    }

    .hp-services-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .hp-svc-card {
      padding: 20px 14px;
    }

    .hp-svc-card h3 {
      font-size: 0.9rem;
    }

    .hp-svc-card p {
      font-size: 0.8rem;
    }

    .hp-about {
      padding: 50px 15px;
      margin: 15px 10px 0;
    }

    .hp-about-grid {
      grid-template-columns: 1fr;
      gap: 25px;
    }

    .hp-about-text {
      padding: 25px;
    }

    .hp-about-stats {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .hp-stat-num, .hp-stat-plus {
      font-size: 2rem;
    }

    .hp-tools {
      padding: 40px 15px;
      margin: 15px 10px 0;
    }

    .hp-tool-card {
      padding: 20px;
      gap: 14px;
    }

    .hp-cta {
      padding: 20px 10px 60px;
      margin-top: 15px;
    }

    .hp-cta-card {
      padding: 40px 24px;
    }

    .hp-cta-buttons {
      flex-direction: column;
      align-items: center;
    }

    .hp-cta-buttons a {
      width: 100%;
      max-width: 280px;
      justify-content: center;
    }
  }
</style>

<script>
  function animateCounters() {
    const counters = document.querySelectorAll('.hp-stat-num[data-target]');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const target = parseInt(el.dataset.target || '0', 10);
          const duration = 1500;
          const start = performance.now();
          function update(now: number) {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            el.textContent = String(Math.round(target * eased));
            if (progress < 1) requestAnimationFrame(update);
          }
          requestAnimationFrame(update);
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.5 });
    counters.forEach(c => observer.observe(c));
  }
  animateCounters();
</script>
