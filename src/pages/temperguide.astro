                <td>UTS 240 MPa, Yield 215 MPa</td>
              </tr>
              <tr>
                <td class="alloy-cell">6063-T5</td>
                <td>N/A (press quench)</td>
                <td>Air / fans</td>
                <td>175&ndash;205&deg;C / 1&ndash;8 hr</td>
                <td>UTS 185 MPa, Yield 145 MPa</td>
              </tr>
              <tr>
                <td class="alloy-cell">7075-T6</td>
