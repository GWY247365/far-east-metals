---
import Layout from '../layouts/Layout.astro';

const alloys = [
  { name: '1100-O', hb: 23, temper: 'Annealed', series: '1xxx' },
  { name: '1100-H14', hb: 32, temper: 'Strain Hardened', series: '1xxx' },
  { name: '2011-T3', hb: 95, temper: 'Solution Treated', series: '2xxx' },
  { name: '2014-T6', hb: 135, temper: 'Aged', series: '2xxx' },
  { name: '2024-T3', hb: 120, temper: 'Solution Treated', series: '2xxx' },
  { name: '2024-T4', hb: 120, temper: 'Naturally Aged', series: '2xxx' },
  { name: '3003-O', hb: 28, temper: 'Annealed', series: '3xxx' },
  { name: '3003-H14', hb: 40, temper: 'Strain Hardened', series: '3xxx' },
  { name: '5052-H32', hb: 60, temper: 'Stabilized', series: '5xxx' },
  { name: '5052-H34', hb: 68, temper: 'Stabilized', series: '5xxx' },
  { name: '5083-O', hb: 75, temper: 'Annealed', series: '5xxx' },
  { name: '5086-H32', hb: 73, temper: 'Stabilized', series: '5xxx' },
  { name: '6061-O', hb: 30, temper: 'Annealed', series: '6xxx' },
  { name: '6061-T4', hb: 65, temper: 'Naturally Aged', series: '6xxx' },
  { name: '6061-T6', hb: 95, temper: 'Aged', series: '6xxx' },
  { name: '6063-T5', hb: 60, temper: 'Artificially Aged', series: '6xxx' },
  { name: '6063-T6', hb: 73, temper: 'Aged', series: '6xxx' },
  { name: '6082-T6', hb: 95, temper: 'Aged', series: '6xxx' },
  { name: '7050-T7451', hb: 140, temper: 'Overaged', series: '7xxx' },
  { name: '7075-T6', hb: 150, temper: 'Aged', series: '7xxx' },
  { name: '7075-T73', hb: 135, temper: 'Overaged', series: '7xxx' },
];

const scales = [
  { id: 'hb', name: 'Brinell', abbr: 'HB', min: 15, max: 650, unit: 'kgf/mm\u00B2', color: '#F5A623' },
  { id: 'hrb', name: 'Rockwell B', abbr: 'HRB', min: 20, max: 100, unit: 'Scale', color: '#4A90D9' },
  { id: 'hrc', name: 'Rockwell C', abbr: 'HRC', min: 20, max: 68, unit: 'Scale', color: '#D94A4A' },
  { id: 'hv', name: 'Vickers', abbr: 'HV', min: 15, max: 940, unit: 'kgf/mm\u00B2', color: '#50B86C' },
  { id: 'hk', name: 'Knoop', abbr: 'HK', min: 15, max: 920, unit: 'kgf/mm\u00B2', color: '#9B59B6' },
  { id: 'shore', name: 'Shore D', abbr: 'Shore D', min: 20, max: 85, unit: 'Scale', color: '#E67E22' },
];
---

<Layout title="Hardness Converter | Far East Metals" description="Free online hardness converter for metals. Convert between Brinell, Rockwell B, Rockwell C, Vickers, Knoop, and Shore D hardness scales. ASTM E140 data.">
  <section class="converter-page">

    <!-- Main content card -->
    <div class="content-card converter-card">
      <!-- Header with SVG animation -->
      <div class="converter-header reveal">
        <svg class="header-svg" viewBox="0 0 400 160" xmlns="http://www.w3.org/2000/svg">
          <!-- Material block -->
          <rect x="100" y="100" width="200" height="50" rx="4" fill="#b0b0b0" stroke="#888" stroke-width="1.5"/>
          <rect x="100" y="100" width="200" height="12" rx="2" fill="#c8c8c8" opacity="0.5"/>
          <!-- Base -->
          <rect x="60" y="150" width="280" height="10" rx="3" fill="#999" stroke="#777" stroke-width="1"/>
          <!-- Indenter body -->
          <g class="indenter-group">
            <rect x="185" y="10" width="30" height="55" rx="3" fill="#666" stroke="#555" stroke-width="1.2"/>
            <rect x="180" y="8" width="40" height="10" rx="2" fill="#777" stroke="#555" stroke-width="1"/>
            <!-- Diamond tip -->
            <polygon points="200,95 192,68 208,68" fill="#50B86C" stroke="#3a8a50" stroke-width="1"/>
            <!-- Force arrows -->
            <line x1="200" y1="0" x2="200" y2="8" stroke="#F5A623" stroke-width="2" marker-end="url(#arrowhead)"/>
            <line x1="188" y1="3" x2="188" y2="8" stroke="#F5A623" stroke-width="1.2" opacity="0.6"/>
            <line x1="212" y1="3" x2="212" y2="8" stroke="#F5A623" stroke-width="1.2" opacity="0.6"/>
          </g>
          <!-- Impression mark -->
          <ellipse class="impression-mark" cx="200" cy="102" rx="6" ry="2" fill="rgba(80,80,80,0.4)" opacity="0"/>
          <defs>
            <marker id="arrowhead" markerWidth="8" markerHeight="6" refX="4" refY="3" orient="auto">
              <polygon points="0,0 8,3 0,6" fill="#F5A623"/>
            </marker>
          </defs>
        </svg>
        <h1 class="page-title">Hardness Converter</h1>
        <p class="page-subtitle">Convert between industry-standard hardness scales for metals and alloys</p>
      </div>
      <div class="input-section content-card-inner reveal">
        <h3 class="section-heading">Enter Hardness Value</h3>
        <div class="input-row">
          <div class="input-group">
            <label for="scale-select">Hardness Scale</label>
            <select id="scale-select">
              {scales.map((s) => (
                <option value={s.id}>{s.name} ({s.abbr})</option>
              ))}
            </select>
          </div>
          <div class="input-group">
            <label for="hardness-input">Value</label>
            <input type="number" id="hardness-input" placeholder="Enter value..." step="0.1" />
            <span class="range-hint" id="range-hint">Range: 15 - 650</span>
          </div>
          <button type="button" class="convert-btn" id="convert-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            Convert
          </button>
        </div>
      </div>

      <!-- Results Section -->
      <div class="results-wrapper" id="results-wrapper" hidden>
        <h3 class="section-heading results-title reveal">Converted Values</h3>
        <div class="results-grid" id="results-grid">
          {scales.map((s, i) => (
            <div class={`result-card reveal reveal-delay-${(i % 3) + 1}`} data-scale={s.id} style={`--scale-color: ${s.color};`}>
              <div class="result-card-inner content-card-inner">
                <div class="gauge-container">
                  <svg class="gauge-svg" viewBox="0 0 120 120">
                    <circle cx="60" cy="60" r="52" fill="none" stroke="rgba(0,0,0,0.06)" stroke-width="8"/>
                    <circle class="gauge-arc" cx="60" cy="60" r="52" fill="none" stroke={s.color} stroke-width="8" stroke-linecap="round"
                      stroke-dasharray="326.73" stroke-dashoffset="326.73" transform="rotate(-90 60 60)"/>
                    <text class="gauge-value" x="60" y="56" text-anchor="middle" dominant-baseline="middle" fill={s.color}>--</text>
                    <text class="gauge-label" x="60" y="76" text-anchor="middle" fill="#888" font-size="10">{s.abbr}</text>
                  </svg>
                </div>
                <div class="result-info">
                  <span class="result-scale-name">{s.name}</span>
                  <span class="result-range">Range: {s.min} - {s.max}</span>
                  <span class="result-status" data-status="valid">--</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Common Aluminum Hardness Reference -->
    <div class="content-card ref-card reveal">
      <div class="ref-title-bar">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2" stroke-linecap="round"><path d="M12 20V10M18 20V4M6 20v-4"/></svg>
        <h2>Common Aluminum Alloy Hardness</h2>
      </div>
      <p class="ref-description">Typical Brinell hardness (HB) values for popular aluminum alloys. Click any alloy to load its value into the converter.</p>
      <div class="alloy-grid">
        {alloys.map((a) => (
          <button type="button" class="alloy-card" data-hb={a.hb} data-alloy={a.name}>
            <span class="alloy-name">{a.name}</span>
            <span class="alloy-hb">{a.hb} <small>HB</small></span>
            <span class="alloy-temper">{a.temper}</span>
            <span class="alloy-series">{a.series}</span>
          </button>
        ))}
      </div>
    </div>

    <!-- Hardness Scale Guide -->
    <div class="content-card guide-card reveal">
      <div class="ref-title-bar">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#F5A623" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
        <h2>Hardness Scale Guide</h2>
      </div>

      <div class="guide-grid">
        <!-- Brinell -->
        <div class="guide-item content-card-inner reveal">
          <div class="guide-svg-wrap">
            <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" class="guide-svg">
              <rect x="10" y="65" width="80" height="30" rx="3" fill="#b0b0b0" stroke="#888" stroke-width="1"/>
              <g class="guide-indenter-brinell">
                <rect x="43" y="15" width="14" height="28" rx="2" fill="#666"/>
                <circle cx="50" cy="48" r="8" fill="#F5A623" stroke="#c88520" stroke-width="1"/>
              </g>
              <ellipse class="guide-impression" cx="50" cy="67" rx="7" ry="2.5" fill="rgba(80,80,80,0.3)" opacity="0"/>
            </svg>
          </div>
          <h4>Brinell (HB)</h4>
          <p>Uses a hardened steel or tungsten carbide ball (10mm) pressed into the material with a known force. The diameter of the resulting impression is measured. Best for softer metals and materials with coarse grain structure.</p>
          <div class="guide-meta">
            <span>Indenter: Ball</span>
            <span>Load: 500-3000 kgf</span>
          </div>
        </div>

        <!-- Rockwell B -->
        <div class="guide-item content-card-inner reveal reveal-delay-1">
          <div class="guide-svg-wrap">
            <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" class="guide-svg">
              <rect x="10" y="65" width="80" height="30" rx="3" fill="#b0b0b0" stroke="#888" stroke-width="1"/>
              <g class="guide-indenter-rockwell-b">
                <rect x="44" y="15" width="12" height="28" rx="2" fill="#666"/>
                <circle cx="50" cy="47" r="5" fill="#4A90D9" stroke="#3670b0" stroke-width="1"/>
              </g>
              <ellipse class="guide-impression" cx="50" cy="67" rx="4.5" ry="2" fill="rgba(80,80,80,0.3)" opacity="0"/>
            </svg>
          </div>
          <h4>Rockwell B (HRB)</h4>
          <p>Uses a 1/16" steel ball indenter with 100 kgf major load. Measures depth of penetration under load. Ideal for aluminum alloys, brass, and softer steels. Fast and non-destructive testing method.</p>
          <div class="guide-meta">
            <span>Indenter: 1/16" Ball</span>
            <span>Load: 100 kgf</span>
          </div>
        </div>

        <!-- Rockwell C -->
        <div class="guide-item content-card-inner reveal reveal-delay-2">
          <div class="guide-svg-wrap">
            <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" class="guide-svg">
              <rect x="10" y="65" width="80" height="30" rx="3" fill="#b0b0b0" stroke="#888" stroke-width="1"/>
              <g class="guide-indenter-rockwell-c">
                <rect x="44" y="15" width="12" height="25" rx="2" fill="#666"/>
                <polygon points="50,52 44,38 56,38" fill="#D94A4A" stroke="#b03030" stroke-width="1"/>
              </g>
              <polygon class="guide-impression-v" points="50,67 47,73 53,73" fill="rgba(80,80,80,0.3)" opacity="0"/>
            </svg>
          </div>
          <h4>Rockwell C (HRC)</h4>
          <p>Uses a diamond cone (Brale) indenter with a 120-degree angle under 150 kgf load. Measures depth of penetration. Primarily for hardened steels and hard alloys, less common for aluminum.</p>
          <div class="guide-meta">
            <span>Indenter: Diamond Cone</span>
            <span>Load: 150 kgf</span>
          </div>
        </div>

        <!-- Vickers -->
        <div class="guide-item content-card-inner reveal">
          <div class="guide-svg-wrap">
            <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" class="guide-svg">
              <rect x="10" y="65" width="80" height="30" rx="3" fill="#b0b0b0" stroke="#888" stroke-width="1"/>
              <g class="guide-indenter-vickers">
                <rect x="44" y="15" width="12" height="22" rx="2" fill="#666"/>
                <polygon points="50,50 43,37 57,37" fill="#50B86C" stroke="#3a9050" stroke-width="1"/>
              </g>
              <polygon class="guide-impression-v" points="50,67 46,74 54,74" fill="rgba(80,80,80,0.3)" opacity="0"/>
            </svg>
          </div>
          <h4>Vickers (HV)</h4>
          <p>Uses a square-based diamond pyramid indenter (136-degree angle) with loads from 1 to 100 kgf. The diagonals of the square impression are measured. Suitable for all metals, including thin sections and surface layers.</p>
          <div class="guide-meta">
            <span>Indenter: Diamond Pyramid</span>
            <span>Load: 1-100 kgf</span>
          </div>
        </div>

        <!-- Knoop -->
        <div class="guide-item content-card-inner reveal reveal-delay-1">
          <div class="guide-svg-wrap">
            <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" class="guide-svg">
              <rect x="10" y="65" width="80" height="30" rx="3" fill="#b0b0b0" stroke="#888" stroke-width="1"/>
              <g class="guide-indenter-knoop">
                <rect x="44" y="15" width="12" height="22" rx="2" fill="#666"/>
                <polygon points="50,50 41,37 59,37" fill="#9B59B6" stroke="#7d3f96" stroke-width="1"/>
              </g>
              <polygon class="guide-impression-v" points="50,67 44,72 56,72" fill="rgba(80,80,80,0.3)" opacity="0"/>
            </svg>
          </div>
          <h4>Knoop (HK)</h4>
          <p>Uses an elongated diamond pyramid indenter producing a rhombic impression. Measures the long diagonal. Excellent for microhardness testing, thin coatings, and brittle materials where crack-free indentation is needed.</p>
          <div class="guide-meta">
            <span>Indenter: Elongated Pyramid</span>
            <span>Load: 0.01-1 kgf</span>
          </div>
        </div>

        <!-- Shore D -->
        <div class="guide-item content-card-inner reveal reveal-delay-2">
          <div class="guide-svg-wrap">
            <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" class="guide-svg">
              <rect x="10" y="65" width="80" height="30" rx="3" fill="#b0b0b0" stroke="#888" stroke-width="1"/>
              <g class="guide-indenter-shore">
                <rect x="44" y="18" width="12" height="20" rx="2" fill="#666"/>
                <rect x="47" y="38" width="6" height="14" rx="1" fill="#E67E22" stroke="#c06818" stroke-width="0.8"/>
              </g>
              <ellipse class="guide-impression" cx="50" cy="67" rx="3" ry="1.5" fill="rgba(80,80,80,0.3)" opacity="0"/>
            </svg>
          </div>
          <h4>Shore D (Durometer)</h4>
          <p>Uses a spring-loaded conical indenter to measure resistance to penetration. Primarily for polymers and elastomers, but used on softer metals. Quick field testing method giving immediate readings on a 0-100 scale.</p>
          <div class="guide-meta">
            <span>Indenter: Conical Pin</span>
            <span>Load: Spring (44.5N)</span>
          </div>
        </div>
      </div>
    </div>

  </section>
</Layout>

<script>
  // ASTM E140 conversion data for non-ferrous metals (aluminum focus)
  // Each row: [HB, HRB, HRC, HV, HK, ShoreD]
  // null = out of valid range for that scale
  const conversionTable: (number | null)[][] = [
    [15, null, null, 15, 15, null],
    [20, null, null, 20, 20, null],
    [25, 22, null, 26, 26, 20],
    [30, 30, null, 31, 31, 22],
    [35, 36, null, 37, 37, 25],
    [40, 42, null, 42, 42, 28],
    [45, 47, null, 47, 47, 30],
    [50, 52, null, 53, 53, 32],
    [55, 56, null, 58, 58, 34],
    [60, 60, null, 63, 63, 36],
    [65, 63, null, 68, 68, 38],
    [70, 66, null, 74, 74, 39],
    [75, 69, null, 79, 79, 41],
    [80, 72, null, 84, 84, 42],
    [85, 74, null, 89, 90, 44],
    [90, 76, null, 95, 96, 45],
    [95, 78, null, 100, 101, 47],
    [100, 80, null, 105, 107, 48],
    [105, 82, null, 110, 112, 49],
    [110, 83, null, 116, 118, 50],
    [115, 84, null, 121, 123, 51],
    [120, 86, null, 127, 129, 52],
    [130, 88, null, 138, 140, 54],
    [140, 90, null, 149, 152, 56],
    [150, 92, null, 160, 163, 58],
    [160, 93, null, 171, 175, 59],
    [170, 94, null, 183, 187, 61],
    [180, 95, null, 194, 198, 62],
    [190, 96, null, 206, 210, 63],
    [200, 97, null, 218, 222, 64],
    [210, 98, 20, 230, 235, 65],
    [220, 99, 21, 243, 248, 66],
    [230, 100, 22, 256, 261, 67],
    [240, null, 23, 269, 275, 68],
    [250, null, 24, 282, 288, 69],
    [260, null, 25, 296, 302, 70],
    [275, null, 27, 316, 323, 72],
    [290, null, 29, 336, 343, 73],
    [310, null, 31, 363, 370, 75],
    [330, null, 34, 390, 398, 77],
    [350, null, 36, 420, 428, 78],
    [375, null, 39, 455, 464, 80],
    [400, null, 41, 492, 502, 81],
    [425, null, 43, 530, 540, 82],
    [450, null, 46, 570, 581, 83],
    [480, null, 48, 615, 627, 84],
    [500, null, 50, 649, 662, 85],
    [530, null, 52, 697, 710, null],
    [560, null, 54, 746, 760, null],
    [600, null, 57, 810, 826, null],
    [630, null, 60, 862, 879, null],
    [650, null, 62, 900, 920, null],
  ];

  const scaleIndices: Record<string, number> = {
    hb: 0, hrb: 1, hrc: 2, hv: 3, hk: 4, shore: 5
  };

  const scaleRanges: Record<string, [number, number]> = {
    hb: [15, 650], hrb: [20, 100], hrc: [20, 68],
    hv: [15, 940], hk: [15, 920], shore: [20, 85]
  };

  function interpolate(x: number, x0: number, x1: number, y0: number, y1: number): number {
    return y0 + (y1 - y0) * ((x - x0) / (x1 - x0));
  }

  function convertHardness(fromScale: string, value: number): Record<string, number | null> {
    const fromIdx = scaleIndices[fromScale];
    const results: Record<string, number | null> = {};

    // Find bracketing rows in table
    let lowerRow: (number | null)[] | null = null;
    let upperRow: (number | null)[] | null = null;

    // Find rows that bracket the input value in the source scale
    for (let i = 0; i < conversionTable.length; i++) {
      const row = conversionTable[i];
      if (row[fromIdx] === null) continue;
      if (row[fromIdx]! <= value) lowerRow = row;
      if (row[fromIdx]! >= value && upperRow === null) upperRow = row;
    }

    for (const [scaleId, idx] of Object.entries(scaleIndices)) {
      if (scaleId === fromScale) {
        results[scaleId] = value;
        continue;
      }

      const [min, max] = scaleRanges[scaleId];

      if (!lowerRow && !upperRow) {
        results[scaleId] = null;
        continue;
      }

      // Exact match or single bracket
      if (lowerRow && upperRow && lowerRow === upperRow) {
        const val = lowerRow[idx];
        results[scaleId] = val !== null && val >= min && val <= max ? Math.round(val * 10) / 10 : null;
        continue;
      }

      if (lowerRow && upperRow) {
        const lv = lowerRow[idx];
        const uv = upperRow[idx];
        const lFrom = lowerRow[fromIdx]!;
        const uFrom = upperRow[fromIdx]!;

        if (lv !== null && uv !== null) {
          const interp = interpolate(value, lFrom, uFrom, lv, uv);
          results[scaleId] = interp >= min && interp <= max ? Math.round(interp * 10) / 10 : null;
        } else if (lv !== null) {
          results[scaleId] = lv >= min && lv <= max ? Math.round(lv * 10) / 10 : null;
        } else if (uv !== null) {
          results[scaleId] = uv >= min && uv <= max ? Math.round(uv * 10) / 10 : null;
        } else {
          results[scaleId] = null;
        }
      } else {
        const row = lowerRow || upperRow;
        const val = row ? row[idx] : null;
        results[scaleId] = val !== null && val >= min && val <= max ? Math.round(val * 10) / 10 : null;
      }
    }

    return results;
  }

  // DOM elements
  const scaleSelect = document.getElementById('scale-select') as HTMLSelectElement;
  const hardnessInput = document.getElementById('hardness-input') as HTMLInputElement;
  const convertBtn = document.getElementById('convert-btn') as HTMLButtonElement;
  const resultsWrapper = document.getElementById('results-wrapper') as HTMLElement;
  const rangeHint = document.getElementById('range-hint') as HTMLElement;

  const scaleRangeMap: Record<string, string> = {
    hb: 'Range: 15 - 650', hrb: 'Range: 20 - 100', hrc: 'Range: 20 - 68',
    hv: 'Range: 15 - 940', hk: 'Range: 15 - 920', shore: 'Range: 20 - 85'
  };

  scaleSelect.addEventListener('change', () => {
    rangeHint.textContent = scaleRangeMap[scaleSelect.value] || '';
  });

  function animateGauge(card: Element, value: number | null, scaleId: string) {
    const arc = card.querySelector('.gauge-arc') as SVGCircleElement;
    const valueText = card.querySelector('.gauge-value') as SVGTextElement;
    const statusEl = card.querySelector('.result-status') as HTMLElement;
    const circumference = 326.73;

    if (value === null) {
      arc.style.transition = 'stroke-dashoffset 0.8s ease-out';
      arc.style.strokeDashoffset = String(circumference);
      valueText.textContent = 'N/A';
      statusEl.textContent = 'Out of range';
      statusEl.dataset.status = 'invalid';
      return;
    }

    const [min, max] = scaleRanges[scaleId];
    const pct = Math.min(1, Math.max(0, (value - min) / (max - min)));
    const offset = circumference * (1 - pct);

    arc.style.transition = 'none';
    arc.style.strokeDashoffset = String(circumference);

    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        arc.style.transition = 'stroke-dashoffset 1s cubic-bezier(0.4, 0, 0.2, 1)';
        arc.style.strokeDashoffset = String(offset);
      });
    });

    // Animate the number
    const duration = 800;
    const start = performance.now();
    const animate = (now: number) => {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = Math.round(value * eased * 10) / 10;
      valueText.textContent = current % 1 === 0 ? String(Math.round(current)) : current.toFixed(1);
      if (progress < 1) requestAnimationFrame(animate);
    };
    requestAnimationFrame(animate);

    statusEl.textContent = 'Valid';
    statusEl.dataset.status = 'valid';
  }

  function doConversion() {
    const fromScale = scaleSelect.value;
    const value = parseFloat(hardnessInput.value);
    if (isNaN(value)) return;

    const [min, max] = scaleRanges[fromScale];
    if (value < min || value > max) {
      hardnessInput.classList.add('input-error');
      setTimeout(() => hardnessInput.classList.remove('input-error'), 600);
      return;
    }

    const results = convertHardness(fromScale, value);

    resultsWrapper.hidden = false;

    // Trigger reveal animations
    resultsWrapper.querySelectorAll('.reveal').forEach(el => el.classList.add('visible'));
    const revealTitle = resultsWrapper.querySelector('.results-title');
    if (revealTitle) revealTitle.classList.add('visible');

    const cards = resultsWrapper.querySelectorAll('.result-card');
    cards.forEach((card, i) => {
      const scaleId = (card as HTMLElement).dataset.scale!;
      setTimeout(() => {
        animateGauge(card, results[scaleId] ?? null, scaleId);
      }, i * 100);
    });
  }

  convertBtn.addEventListener('click', doConversion);
  hardnessInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') doConversion();
  });

  // Alloy click handlers
  document.querySelectorAll('.alloy-card').forEach(card => {
    card.addEventListener('click', () => {
      const hb = (card as HTMLElement).dataset.hb;
      scaleSelect.value = 'hb';
      hardnessInput.value = hb || '';
      rangeHint.textContent = scaleRangeMap['hb'];
      doConversion();
      resultsWrapper.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
  });
</script>

