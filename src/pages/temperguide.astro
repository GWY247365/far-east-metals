    .strength-fill,
    .bar-fill,
    .comp-bar {
      transition: none;
    }
  }
</style>

<script>
  // Accordion toggle for T temper items
  document.querySelectorAll('.t-temper-header').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      // Close all
      document.querySelectorAll('.t-temper-header').forEach(b => {
        b.setAttribute('aria-expanded', 'false');
        const body = b.parentElement?.querySelector('.t-temper-body');
        body?.classList.remove('open');
      });
      // Toggle clicked
      if (!expanded) {
        btn.setAttribute('aria-expanded', 'true');
        const body = btn.parentElement?.querySelector('.t-temper-body');
        body?.classList.add('open');
      }
    });
  });

  // Animate bars on scroll into view
  const barObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        // Strength bars (H temper)
        entry.target.querySelectorAll('.strength-fill').forEach((bar: HTMLElement) => {
          const w = bar.dataset.width;
          if (w) bar.style.width = Math.min(parseFloat(w), 100) + '%';
        });
        // Bar chart fills
        entry.target.querySelectorAll('.bar-fill').forEach((bar: HTMLElement) => {
          const w = bar.dataset.width;
          if (w) bar.style.width = w + '%';
        });
        // Comparison bars
        entry.target.querySelectorAll('.comp-bar').forEach((bar: HTMLElement) => {
          const w = bar.dataset.width;
          if (w) bar.style.width = w + '%';
        });
        barObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.h-degree-grid, .bar-chart, .comp-bars').forEach(el => {
    barObserver.observe(el);
  });

  // Scroll reveal (supplement Layout's observer for dynamically visible elements)
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.temper-page .reveal').forEach(el => revealObserver.observe(el));
</script>
