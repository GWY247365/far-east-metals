---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About | Far East Metals" description="Learn about Far East Metals Development Limited - Hong Kong's aluminum industry leader since 2003. Specializing in extrusion, forging, and ingot production with a network of 100+ factories.">
  <section class="about-page">
    <div class="content-card">
      <h1 class="reveal">About Far East Metals</h1>
      <p class="intro reveal reveal-delay-1">
        Founded in 2003 with its headquarters in Hong Kong, Far East Metals Development Limited stands as a prominent industry leader, specializing in aluminum extrusion, forging, and ingot production. Our primary commitment is to cultivate robust partnerships between our Chinese clientele and global customers.
      </p>

      <!-- Stats Counter -->
      <div class="stats-bar reveal">
        <div class="stat-item">
          <span class="stat-number" data-target="20">0</span><span class="stat-suffix">+</span>
          <span class="stat-label">Years in Industry</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" data-target="100">0</span><span class="stat-suffix">+</span>
          <span class="stat-label">Partner Factories</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" data-target="30">0</span><span class="stat-suffix">+</span>
          <span class="stat-label">Countries Served</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" data-target="8">0</span>
          <span class="stat-label">Core Processes</span>
        </div>
      </div>

      <div class="features-grid">
        <div class="feature-card content-card-inner reveal">
          <div class="feature-icon">
            <svg viewBox="0 0 64 64" width="48" height="48"><circle cx="32" cy="32" r="28" fill="none" stroke="var(--color-accent)" stroke-width="2"/><path d="M20 44V20h8l6 12 6-12h8v24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3>Manufacturing Network</h3>
          <p>Extensive network of over 100 factories offering comprehensive aluminum production processes across China</p>
        </div>
        <div class="feature-card content-card-inner reveal reveal-delay-1">
          <div class="feature-icon">
            <svg viewBox="0 0 64 64" width="48" height="48"><circle cx="32" cy="32" r="28" fill="none" stroke="var(--color-accent)" stroke-width="2"/><circle cx="32" cy="26" r="8" fill="none" stroke="var(--color-accent)" stroke-width="2"/><path d="M18 48c0-8 6-14 14-14s14 6 14 14" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round"/></svg>
          </div>
          <h3>Global Presence</h3>
          <p>Supporting manufacturers and distributors in establishing a formidable global presence across 30+ countries</p>
        </div>
        <div class="feature-card content-card-inner reveal reveal-delay-2">
          <div class="feature-icon">
            <svg viewBox="0 0 64 64" width="48" height="48"><circle cx="32" cy="32" r="28" fill="none" stroke="var(--color-accent)" stroke-width="2"/><path d="M22 34l6 6 14-16" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h3>Premium Quality</h3>
          <p>Delivering premium products and services tailored to precise specifications with rigorous quality control</p>
        </div>
      </div>

      <!-- Manufacturing Process Flow -->
      <div class="process-section reveal">
        <h2>Manufacturing Process</h2>
        <p class="section-desc">From raw material to finished product, our integrated manufacturing process ensures consistent quality at every stage.</p>
        <div class="process-flow">
          <div class="process-step reveal">
            <div class="process-icon">
              <svg viewBox="0 0 80 80" width="56" height="56">
                <rect x="15" y="30" width="50" height="35" rx="3" fill="none" stroke="var(--color-accent)" stroke-width="2"/>
                <path d="M25 30V20a15 15 0 0 1 30 0v10" fill="none" stroke="var(--color-accent)" stroke-width="2"/>
                <circle cx="40" cy="47" r="5" fill="var(--color-accent)" opacity="0.3"/>
                <line x1="40" y1="47" x2="40" y2="55" stroke="var(--color-accent)" stroke-width="2"/>
              </svg>
            </div>
            <h4>Raw Material</h4>
            <p>Premium aluminum ingots and billets sourced from certified suppliers</p>
          </div>
          <div class="process-arrow">
            <svg width="24" height="24" viewBox="0 0 24 24"><path d="M5 12h14m-7-7l7 7-7 7" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div class="process-step reveal reveal-delay-1">
            <div class="process-icon">
              <svg viewBox="0 0 80 80" width="56" height="56">
                <rect x="10" y="25" width="60" height="30" rx="3" fill="none" stroke="var(--color-accent)" stroke-width="2"/>
                <line x1="10" y1="40" x2="70" y2="40" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.4"/>
                <circle cx="25" cy="40" r="8" fill="none" stroke="var(--color-accent)" stroke-width="2">
                  <animateTransform attributeName="transform" type="rotate" from="0 25 40" to="360 25 40" dur="3s" repeatCount="indefinite"/>
                </circle>
                <circle cx="55" cy="40" r="8" fill="none" stroke="var(--color-accent)" stroke-width="2">
                  <animateTransform attributeName="transform" type="rotate" from="360 55 40" to="0 55 40" dur="3s" repeatCount="indefinite"/>
                </circle>
              </svg>
            </div>
            <h4>Processing</h4>
            <p>Extrusion, forging, rolling, stamping, or die casting based on requirements</p>
          </div>
          <div class="process-arrow">
            <svg width="24" height="24" viewBox="0 0 24 24"><path d="M5 12h14m-7-7l7 7-7 7" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div class="process-step reveal reveal-delay-2">
            <div class="process-icon">
              <svg viewBox="0 0 80 80" width="56" height="56">
                <rect x="20" y="20" width="40" height="40" rx="3" fill="none" stroke="var(--color-accent)" stroke-width="2"/>
                <path d="M30 35h20M30 45h15" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round"/>
                <circle cx="55" cy="25" r="8" fill="none" stroke="var(--color-accent)" stroke-width="2"/>
                <path d="M52 25l3 3 5-6" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h4>Quality Control</h4>
            <p>Rigorous inspection and testing at every production stage</p>
          </div>
          <div class="process-arrow">
            <svg width="24" height="24" viewBox="0 0 24 24"><path d="M5 12h14m-7-7l7 7-7 7" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div class="process-step reveal reveal-delay-3">
            <div class="process-icon">
              <svg viewBox="0 0 80 80" width="56" height="56">
                <rect x="15" y="30" width="50" height="30" rx="3" fill="none" stroke="var(--color-accent)" stroke-width="2"/>
                <path d="M15 40h50" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.4"/>
                <path d="M30 20l10 10 10-10" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <animate attributeName="d" values="M30 20l10 10 10-10;M30 25l10 5 10-5;M30 20l10 10 10-10" dur="2s" repeatCount="indefinite"/>
                </path>
              </svg>
            </div>
            <h4>Delivery</h4>
            <p>Global logistics network ensuring timely delivery worldwide</p>
          </div>
        </div>
      </div>

      <!-- Core Processes Detail -->
      <div class="processes-detail reveal">
        <h2>Our Core Processes</h2>
        <div class="process-cards">

          <div class="process-card content-card-inner reveal">
            <div class="process-card-icon">
              <svg viewBox="0 0 80 80" width="44" height="44">
                <rect x="10" y="30" width="25" height="20" rx="2" fill="var(--color-accent)" opacity="0.2" stroke="var(--color-accent)" stroke-width="1.5"/>
                <rect x="35" y="25" width="10" height="30" rx="1" fill="none" stroke="var(--color-accent)" stroke-width="1.5"/>
                <line x1="45" y1="40" x2="72" y2="40" stroke="var(--color-accent)" stroke-width="3" stroke-linecap="round">
                  <animate attributeName="x1" values="45;50;45" dur="1.5s" repeatCount="indefinite"/>
                </line>
              </svg>
            </div>
            <div class="process-card-content">
              <h3>Aluminum Extrusion</h3>
              <p>Heated aluminum billets are forced through a shaped die to create profiles with consistent cross-sections. Ideal for architectural frames, heat sinks, and structural components.</p>
              <div class="process-tags">
                <span class="process-tag">Profiles</span>
                <span class="process-tag">Heat Sinks</span>
                <span class="process-tag">Frames</span>
              </div>
            </div>
          </div>

          <div class="process-card content-card-inner reveal">
            <div class="process-card-icon">
              <svg viewBox="0 0 80 80" width="44" height="44">
                <path d="M25 55 L40 25 L55 55 Z" fill="var(--color-accent)" opacity="0.2" stroke="var(--color-accent)" stroke-width="1.5" stroke-linejoin="round"/>
                <line x1="40" y1="15" x2="40" y2="30" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round">
                  <animate attributeName="y2" values="25;30;25" dur="1s" repeatCount="indefinite"/>
                </line>
                <rect x="35" y="10" width="10" height="8" rx="1" fill="none" stroke="var(--color-accent)" stroke-width="1.5"/>
              </svg>
            </div>
            <div class="process-card-content">
              <h3>Precision Forging</h3>
              <p>Metal is shaped using compressive forces, producing parts with superior strength and grain structure. Used extensively in automotive, aerospace, and machinery applications.</p>
              <div class="process-tags">
                <span class="process-tag">Automotive</span>
                <span class="process-tag">Aerospace</span>
                <span class="process-tag">Machinery</span>
              </div>
            </div>
          </div>

          <div class="process-card content-card-inner reveal">
            <div class="process-card-icon">
              <svg viewBox="0 0 80 80" width="44" height="44">
                <rect x="10" y="35" width="60" height="10" rx="2" fill="var(--color-accent)" opacity="0.2" stroke="var(--color-accent)" stroke-width="1.5"/>
                <line x1="15" y1="30" x2="65" y2="30" stroke="var(--color-accent)" stroke-width="2"/>
                <line x1="15" y1="50" x2="65" y2="50" stroke="var(--color-accent)" stroke-width="2"/>
                <circle cx="20" cy="40" r="4" fill="var(--color-accent)" opacity="0.4">
                  <animate attributeName="cx" values="20;60;20" dur="2s" repeatCount="indefinite"/>
                </circle>
              </svg>
            </div>
            <div class="process-card-content">
              <h3>Flat Rolling</h3>
              <p>Aluminum slabs are passed through rolling mills to produce sheets and plates of precise thickness. Essential for packaging, construction panels, and marine applications.</p>
              <div class="process-tags">
                <span class="process-tag">Sheets</span>
                <span class="process-tag">Plates</span>
                <span class="process-tag">Coils</span>
              </div>
            </div>
          </div>

          <div class="process-card content-card-inner reveal">
            <div class="process-card-icon">
              <svg viewBox="0 0 80 80" width="44" height="44">
                <rect x="20" y="20" width="40" height="40" rx="3" fill="var(--color-accent)" opacity="0.2" stroke="var(--color-accent)" stroke-width="1.5"/>
                <path d="M30 45 L40 30 L50 45" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <animate attributeName="d" values="M30 45 L40 30 L50 45;M30 42 L40 33 L50 42;M30 45 L40 30 L50 45" dur="1.5s" repeatCount="indefinite"/>
                </path>
              </svg>
            </div>
            <div class="process-card-content">
              <h3>Die Casting</h3>
              <p>Molten aluminum is injected into precision molds under high pressure, creating complex shapes with excellent surface finish and dimensional accuracy.</p>
              <div class="process-tags">
                <span class="process-tag">Complex Parts</span>
                <span class="process-tag">High Volume</span>
                <span class="process-tag">Precision</span>
              </div>
            </div>
          </div>

          <div class="process-card content-card-inner reveal">
            <div class="process-card-icon">
              <svg viewBox="0 0 80 80" width="44" height="44">
                <circle cx="40" cy="40" r="20" fill="var(--color-accent)" opacity="0.2" stroke="var(--color-accent)" stroke-width="1.5"/>
                <circle cx="40" cy="40" r="10" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-dasharray="4 3">
                  <animateTransform attributeName="transform" type="rotate" from="0 40 40" to="360 40 40" dur="4s" repeatCount="indefinite"/>
                </circle>
              </svg>
            </div>
            <div class="process-card-content">
              <h3>Surface Treatment</h3>
              <p>Anodizing, powder coating, polishing, and other finishing processes to enhance corrosion resistance, appearance, and durability of aluminum products.</p>
              <div class="process-tags">
                <span class="process-tag">Anodizing</span>
                <span class="process-tag">Powder Coating</span>
                <span class="process-tag">Polishing</span>
              </div>
            </div>
          </div>

          <div class="process-card content-card-inner reveal">
            <div class="process-card-icon">
              <svg viewBox="0 0 80 80" width="44" height="44">
                <path d="M20 55 Q40 20 60 55" fill="none" stroke="var(--color-accent)" stroke-width="2"/>
                <circle cx="40" cy="35" r="4" fill="var(--color-accent)" opacity="0.5">
                  <animate attributeName="r" values="3;5;3" dur="1.5s" repeatCount="indefinite"/>
                  <animate attributeName="opacity" values="0.5;0.2;0.5" dur="1.5s" repeatCount="indefinite"/>
                </circle>
                <line x1="25" y1="60" x2="55" y2="60" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="process-card-content">
              <h3>Heat Treatment</h3>
              <p>Controlled heating and cooling processes to optimize mechanical properties including strength, hardness, and ductility of aluminum alloys.</p>
              <div class="process-tags">
                <span class="process-tag">T5</span>
                <span class="process-tag">T6</span>
                <span class="process-tag">Annealing</span>
              </div>
            </div>
          </div>

        </div>
      </div>

      <div class="services-section content-card-inner reveal">
        <h2>Our Services</h2>
        <ul class="services-list">
          <li>Extruding</li>
          <li>Flat rolling</li>
          <li>Forging</li>
          <li>Deep processing</li>
          <li>Stamping</li>
          <li>Surface treatment</li>
          <li>Die Casting</li>
          <li>Heat treatment</li>
        </ul>
        <p class="services-desc">
          With our extensive manufacturing capabilities, we offer a comprehensive array of aluminum production processes to accommodate diverse requirements.
        </p>
      </div>

      <div class="wyeetech-section content-card-inner reveal">
        <h2>Wyeetech Technology Limited</h2>
        <p>
          <a href="https://www.wyeetech.com/" target="_blank" rel="noopener noreferrer">Wyeetech Technology Limited</a>, a National High-Tech Enterprise and subsidiary of Far East Metals Development Limited, specializes in precision forging and extruding. This further contributes to our unwavering commitment to excellence in the industry.
        </p>
      </div>

      <div class="brochure-section content-card-inner reveal">
        <a href="/brochure.pdf" class="brochure-link" download="Far_East_Metals_Brochure.pdf">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          <span>Download Our Company Brochure</span>
          <span class="brochure-size">PDF, 3.6 MB</span>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .about-page {
    padding: 100px 20px 60px;
  }

  .intro {
    margin-bottom: 30px;
    font-size: 0.95rem;
  }

  /* Stats Bar */
  .stats-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 35px;
    padding: 30px 20px;
    background: linear-gradient(135deg, var(--color-accent), #d4891a, #c07818);
    border-radius: 22px;
    text-align: center;
    position: relative;
    overflow: hidden;
    box-shadow: 0 8px 35px rgba(245, 166, 35, 0.2);
  }

  .stats-bar::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 200%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.08), transparent);
    animation: about-shimmer 6s ease-in-out infinite;
  }

  @keyframes about-shimmer {
    0% { transform: translateX(-30%); }
    50% { transform: translateX(30%); }
    100% { transform: translateX(-30%); }
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-number {
    font-size: 2.4rem;
    font-weight: 600;
    color: white;
    line-height: 1;
    font-family: var(--font-title);
  }

  .stat-suffix {
    font-size: 2.4rem;
    font-weight: 600;
    color: white;
    line-height: 1;
    font-family: var(--font-title);
  }

  .stat-label {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.85);
    margin-top: 6px;
    font-weight: 400;
  }

  /* Feature Icons */
  .feature-icon {
    margin-bottom: 15px;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 30px;
  }

  .feature-card {
    padding: 30px;
    text-align: center;
  }

  .feature-card h3 {
    font-size: 1.05rem;
  }

  .feature-card p {
    font-size: 0.9rem;
  }

  /* Process Flow */
  .process-section {
    margin-bottom: 30px;
  }

  .process-section h2 {
    margin-bottom: 8px;
  }

  .section-desc {
    margin-bottom: 25px;
  }

  .process-flow {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 8px;
  }

  .process-step {
    flex: 1;
    text-align: center;
    padding: 20px 10px;
    background: rgba(255, 255, 255, 0.65);
    border-radius: 16px;
    border: 1px solid rgba(245, 166, 35, 0.12);
    transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .process-step:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(245, 166, 35, 0.1);
    border-color: rgba(245, 166, 35, 0.35);
    background: rgba(255, 255, 255, 0.85);
  }

  .process-icon {
    margin-bottom: 12px;
  }

  .process-step h4 {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 6px;
  }

  .process-step p {
    font-size: 0.78rem;
    line-height: 1.5;
  }

  .process-arrow {
    display: flex;
    align-items: center;
    padding-top: 40px;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  /* Process Detail Cards */
  .processes-detail {
    margin-bottom: 30px;
  }

  .processes-detail h2 {
    margin-bottom: 20px;
  }

  .process-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .process-card {
    display: flex;
    gap: 16px;
    padding: 24px;
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .process-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
  }

  .process-card-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
  }

  .process-card-content h3 {
    font-size: 1rem;
    margin-bottom: 6px;
  }

  .process-card-content p {
    font-size: 0.85rem;
    margin-bottom: 10px;
  }

  .process-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .process-tag {
    font-size: 0.72rem;
    padding: 3px 10px;
    background: rgba(245, 166, 35, 0.1);
    color: var(--color-accent);
    border-radius: 20px;
    font-weight: 500;
  }

  /* Services */
  .services-section {
    margin-bottom: 30px;
  }

  .services-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px 30px;
    list-style: none;
    margin: 15px 0;
    padding: 0;
  }

  .services-list li {
    font-size: 0.9rem;
    color: var(--color-text-light);
    padding: 6px 0;
    border-bottom: 1px solid rgba(245, 166, 35, 0.12);
  }

  .services-desc {
    margin-top: 15px;
  }

  .wyeetech-section {
    margin-bottom: 30px;
  }

  .wyeetech-section a {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }

  .wyeetech-section a:hover {
    text-decoration: underline;
  }

  .brochure-section {
    text-align: center;
  }

  .brochure-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 600;
    padding: 18px 24px;
    background: linear-gradient(135deg, var(--color-accent), #d4891a);
    color: white;
    border-radius: 16px;
    transition: all 0.3s;
    box-shadow: 0 4px 15px rgba(245, 166, 35, 0.2);
  }

  .brochure-link:hover {
    background: linear-gradient(135deg, #d4891a, #c07818);
    box-shadow: 0 6px 20px rgba(245, 166, 35, 0.3);
    transform: translateY(-2px);
  }

  .brochure-size {
    font-size: 0.75rem;
    font-weight: 400;
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .stats-bar {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px 10px;
      padding: 25px 15px;
    }

    .stat-number, .stat-suffix {
      font-size: 1.8rem;
    }

    .features-grid {
      grid-template-columns: 1fr;
    }

    .process-flow {
      flex-direction: column;
      align-items: stretch;
    }

    .process-arrow {
      justify-content: center;
      padding-top: 0;
      transform: rotate(90deg);
    }

    .process-cards {
      grid-template-columns: 1fr;
    }

    .process-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .services-list {
      grid-template-columns: 1fr;
    }

    .brochure-link {
      flex-direction: column;
      gap: 6px;
      padding: 20px;
      font-size: 1rem;
    }

    .brochure-link svg {
      width: 32px;
      height: 32px;
    }

    .brochure-size {
      font-size: 0.8rem;
    }
  }
</style>

<script>
  // Animated counter
  function animateCounters() {
    const counters = document.querySelectorAll('.stat-number[data-target]');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const target = parseInt(el.dataset.target || '0', 10);
          const duration = 1500;
          const start = performance.now();

          function update(now: number) {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            el.textContent = String(Math.round(target * eased));
            if (progress < 1) requestAnimationFrame(update);
          }

          requestAnimationFrame(update);
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.5 });

    counters.forEach(c => observer.observe(c));
  }

  animateCounters();
</script>
