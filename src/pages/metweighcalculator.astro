  let currentMaterial = 'Aluminum';

  // Grade dropdown elements
  const gradeDropdown = document.getElementById('grade-dropdown')!;
  const gradeTrigger = document.getElementById('grade-trigger')!;
  const gradeTriggerText = document.getElementById('grade-trigger-text')!;
  const gradePanel = document.getElementById('grade-panel')!;
  const gradeSearch = document.getElementById('grade-search') as HTMLInputElement;
  const gradeList = document.getElementById('grade-list')!;

  function renderGrades(filter = '') {
    const data = gradeData[currentMaterial] || [];
    const lowerFilter = filter.toLowerCase();
    let html = '';

    for (const cat of data) {
      const filtered = cat.grades.filter(g =>
        !filter ||
        g.name.toLowerCase().includes(lowerFilter) ||
        g.desc.toLowerCase().includes(lowerFilter) ||
        g.tags.some(t => t.toLowerCase().includes(lowerFilter))
      );
      if (filtered.length === 0) continue;

      html += `<div class="grade-category">${cat.category}</div>`;
      for (const g of filtered) {
        html += `<button type="button" class="grade-option" data-density="${g.density}" data-name="${g.name}">
          <div class="grade-header"><span class="grade-name">${g.name}</span><span class="grade-density">${g.density} g/cm\u00B3</span></div>
          <div class="grade-desc">${g.desc}</div>
          <div class="grade-tags">${g.tags.map(t => `<span class="grade-tag">${t}</span>`).join('')}</div>
        </button>`;
      }
    }

    if (!html) {
      html = '<div class="grade-empty">No grades found</div>';
    }

    gradeList.innerHTML = html;

    // Bind click events
    gradeList.querySelectorAll('.grade-option').forEach(btn => {
      btn.addEventListener('click', () => {
        const density = parseFloat(btn.getAttribute('data-density')!);
        const name = btn.getAttribute('data-name')!;
        selectedDensity = density;
        gradeSelected = true;
        gradeTriggerText.textContent = name;
        gradeDropdown.classList.remove('open');
        calculate();
      });
    });
  }

  function updateGradesForMaterial() {
    gradeSelected = false;
    selectedDensity = 0;
    gradeTriggerText.textContent = 'Select a grade...';
    gradeSearch.value = '';
    renderGrades();
  }

  // Toggle dropdown
  gradeTrigger.addEventListener('click', () => {
    gradeDropdown.classList.toggle('open');
    if (gradeDropdown.classList.contains('open')) {
      gradeSearch.focus();
    }
  });

  // Search
  gradeSearch.addEventListener('input', () => {
    renderGrades(gradeSearch.value);
  });

  // Close on click outside
  document.addEventListener('click', (e) => {
    if (!gradeDropdown.contains(e.target as Node)) {
      gradeDropdown.classList.remove('open');
    }
  });

  // Material selection
  document.querySelectorAll('.material-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.material-btn').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      selectedDensity = parseFloat(btn.getAttribute('data-density')!);
      currentMaterial = btn.getAttribute('data-name')!;
      updateGradesForMaterial();
      calculate();
    });
  });
  // Select first material by default
  document.querySelector('.material-btn')?.classList.add('selected');

  const shapeSelect = document.getElementById('shape-select') as HTMLSelectElement;
  const unitSelect = document.getElementById('unit-select') as HTMLSelectElement;
  const dimInputs = document.getElementById('dimension-inputs')!;

  const shapeFields: Record<string, { label: string; id: string }[]> = {
    'cylinder': [
      { label: 'Diameter', id: 'diameter' },
      { label: 'Length', id: 'length' },
    ],
    'hollow-cylinder': [
      { label: 'Outer Diameter', id: 'outer-diameter' },
      { label: 'Inner Diameter', id: 'inner-diameter' },
      { label: 'Length', id: 'length' },
    ],
    'rectangular': [
      { label: 'Width', id: 'width' },
      { label: 'Height', id: 'height' },
      { label: 'Length', id: 'length' },
    ],
    'sheet': [
      { label: 'Width', id: 'width' },
      { label: 'Length', id: 'length' },
      { label: 'Thickness', id: 'thickness' },
    ],
    'hex': [
      { label: 'Across Flats', id: 'across-flats' },
      { label: 'Length', id: 'length' },
    ],
  };

  function getUnitLabel() {
    const u = unitSelect.value;
    return u === 'mm' ? 'Mm' : u === 'cm' ? 'Cm' : 'In';
  }

  function renderFields() {
    const fields = shapeFields[shapeSelect.value];
    const unit = getUnitLabel();
    dimInputs.innerHTML = fields.map(f =>
      `<div class="dim-field">
        <label>${f.label} (${unit})</label>
        <input type="number" id="${f.id}" placeholder="Enter ${f.label.toLowerCase()}" min="0" step="any" />
      </div>`
    ).join('');
    dimInputs.querySelectorAll('input').forEach(input => {
      input.addEventListener('input', calculate);
    });
  }

  function getVal(id: string): number {
    const el = document.getElementById(id) as HTMLInputElement | null;
    return el ? parseFloat(el.value) || 0 : 0;
  }

  function toMm(val: number): number {
    const unit = unitSelect.value;
    if (unit === 'cm') return val * 10;
    if (unit === 'in') return val * 25.4;
    return val;
  }

  function calculate() {
    const shape = shapeSelect.value;
    let volumeMm3 = 0;

    switch (shape) {
      case 'cylinder': {
        const d = toMm(getVal('diameter'));
        const l = toMm(getVal('length'));
        volumeMm3 = PI * (d / 2) ** 2 * l;
        break;
      }
      case 'hollow-cylinder': {
        const od = toMm(getVal('outer-diameter'));
        const id = toMm(getVal('inner-diameter'));
        const l = toMm(getVal('length'));
        volumeMm3 = PI * ((od / 2) ** 2 - (id / 2) ** 2) * l;
        break;
      }
      case 'rectangular': {
        const w = toMm(getVal('width'));
        const h = toMm(getVal('height'));
        const l = toMm(getVal('length'));
        volumeMm3 = w * h * l;
        break;
      }
      case 'sheet': {
        const w = toMm(getVal('width'));
        const l = toMm(getVal('length'));
        const t = toMm(getVal('thickness'));
        volumeMm3 = w * l * t;
        break;
      }
      case 'hex': {
        const af = toMm(getVal('across-flats'));
        const l = toMm(getVal('length'));
        volumeMm3 = (3 * Math.sqrt(3) / 2) * (af / 2) ** 2 * l;
        break;
      }
    }

    // density is g/cm³, 1 cm³ = 1000 mm³
    const weightG = volumeMm3 * selectedDensity / 1000;

    // Show/hide results section
    const resultsSection = document.getElementById('results-section')!;
    if (volumeMm3 <= 0 || !gradeSelected) {
      resultsSection.hidden = true;
      return;
    }
    resultsSection.hidden = false;

    // Display volume
    const volUnit = (document.getElementById('volume-unit') as HTMLSelectElement).value;
    let displayVol = volumeMm3;
    if (volUnit === 'cm3') displayVol = volumeMm3 / 1000;
    if (volUnit === 'in3') displayVol = volumeMm3 / 16387.064;
    document.getElementById('volume-result')!.textContent =
      displayVol < 0.01 && displayVol > 0 ? displayVol.toExponential(2) : displayVol.toLocaleString('en', { maximumFractionDigits: 2 });

    // Display weight
    const wtUnit = (document.getElementById('weight-unit') as HTMLSelectElement).value;
    let displayWt = weightG;
    if (wtUnit === 'kg') displayWt = weightG / 1000;
    if (wtUnit === 'lb') displayWt = weightG / 453.592;
    document.getElementById('weight-result')!.textContent =
      displayWt.toLocaleString('en', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  shapeSelect.addEventListener('change', () => { renderFields(); calculate(); });
  unitSelect.addEventListener('change', () => { renderFields(); calculate(); });
  document.getElementById('volume-unit')!.addEventListener('change', calculate);
  document.getElementById('weight-unit')!.addEventListener('change', calculate);

  renderFields();
  renderGrades();
</script>

