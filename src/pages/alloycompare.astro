function getAlloyList(series) {
  return Object.entries(ALLOYS)
    .filter(([,a]) => series === "all" || a.series === series)
    .sort((a,b) => a[0].localeCompare(b[0], undefined, {numeric:true}));
}

function populateDropdowns() {
  for (let i = 0; i < 3; i++) {
    const container = document.getElementById(`options-${i}`);
    container.innerHTML = "";
    const list = getAlloyList(selectedSeries);
    list.forEach(([id, alloy]) => {
      const div = document.createElement("div");
      div.className = "select-option";
      div.dataset.alloy = id;
      div.innerHTML = `<span>${id}</span><span class="opt-series">${alloy.series}</span>`;
      div.addEventListener("click", () => selectAlloy(i, id));
      container.appendChild(div);
    });
  }
}

function bindSeriesCards() {
  document.querySelectorAll(".series-card").forEach(card => {
    card.addEventListener("click", () => {
      document.querySelectorAll(".series-card").forEach(c => c.classList.remove("active"));
      card.classList.add("active");
      selectedSeries = card.dataset.series;
      populateDropdowns();
    });
  });
}

function bindSelectors() {
  for (let i = 0; i < 3; i++) {
    const wrap = document.getElementById(`select-wrap-${i}`);
    const trigger = document.getElementById(`trigger-${i}`);
    const search = document.getElementById(`search-${i}`);

    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      document.querySelectorAll(".custom-select.open").forEach(s => {
        if (s !== wrap) s.classList.remove("open");
      });
      wrap.classList.toggle("open");
      if (wrap.classList.contains("open")) {
        search.value = "";
        filterOptions(i, "");
        setTimeout(() => search.focus(), 50);
      }
    });

    search.addEventListener("input", () => filterOptions(i, search.value));
    search.addEventListener("click", e => e.stopPropagation());
  }

  document.addEventListener("click", () => {
    document.querySelectorAll(".custom-select.open").forEach(s => s.classList.remove("open"));
  });
}

function filterOptions(idx, term) {
  const container = document.getElementById(`options-${idx}`);
  const t = term.toLowerCase();
  container.querySelectorAll(".select-option").forEach(opt => {
    const id = opt.dataset.alloy;
    const alloy = ALLOYS[id];
    const searchStr = `${id} ${alloy.series} ${alloy.applications} ${alloy.standards}`.toLowerCase();
    opt.style.display = searchStr.includes(t) ? "" : "none";
  });
}

function selectAlloy(idx, id) {
  selections[idx] = id;
  const trigger = document.getElementById(`trigger-${idx}`);
  document.getElementById(`text-${idx}`).textContent = id;
  trigger.classList.add("has-value");
  document.getElementById(`select-wrap-${idx}`).classList.remove("open");
  updateCompareBtn();
}

function updateCompareBtn() {
  const count = selections.filter(Boolean).length;
  document.getElementById("btn-compare").disabled = count < 2;
}

function bindActions() {
  document.getElementById("btn-compare").addEventListener("click", runComparison);
  document.getElementById("btn-reset").addEventListener("click", resetAll);
}

function resetAll() {
  selections = [null, null, null];
  for (let i = 0; i < 3; i++) {
    document.getElementById(`text-${i}`).textContent = "Choose alloy...";
    document.getElementById(`trigger-${i}`).classList.remove("has-value");
  }
  updateCompareBtn();
  document.getElementById("radar-section").style.display = "none";
  document.getElementById("comparison-section").style.display = "none";
}

function runComparison() {
  const chosen = selections.filter(Boolean);
  if (chosen.length < 2) return;
  buildRadarChart(chosen);
  buildComparisonTable(chosen);
  document.getElementById("radar-section").style.display = "";
  document.getElementById("comparison-section").style.display = "";

  // Re-observe for reveal
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add("visible"); obs.unobserve(e.target); }});
  }, { threshold: 0.05 });
  document.querySelectorAll("#radar-section, #comparison-section").forEach(el => {
    el.classList.remove("visible");
    el.classList.add("reveal");
    obs.observe(el);
  });

  document.getElementById("radar-section").scrollIntoView({ behavior:"smooth", block:"start" });

  // Animate bars after short delay
  setTimeout(() => {
    document.querySelectorAll(".bar-fill").forEach(bar => {
      bar.style.width = bar.dataset.width + "%";
    });
  }, 200);
}

// ===== RADAR CHART (Pure CSS/SVG) =====
function buildRadarChart(alloyIds) {
  const chart = document.getElementById("radar-chart");
  const legend = document.getElementById("radar-legend");
  const n = RADAR_PROPS.length;
  const cx = 190, cy = 190, R = 150;
  const angleStep = (2 * Math.PI) / n;

  // Build SVG
  let svg = `<svg viewBox="0 0 380 380" style="width:100%;height:100%;">`;

  // Grid rings
  for (let ring = 1; ring <= 5; ring++) {
    const r = (R / 5) * ring;
    let pts = [];
    for (let i = 0; i < n; i++) {
      const angle = -Math.PI / 2 + i * angleStep;
      pts.push(`${cx + r * Math.cos(angle)},${cy + r * Math.sin(angle)}`);
    }
    svg += `<polygon points="${pts.join(" ")}" fill="none" stroke="rgba(0,0,0,0.08)" stroke-width="1"/>`;
  }

  // Axes and labels
  for (let i = 0; i < n; i++) {
    const angle = -Math.PI / 2 + i * angleStep;
    const x2 = cx + R * Math.cos(angle);
    const y2 = cy + R * Math.sin(angle);
    svg += `<line x1="${cx}" y1="${cy}" x2="${x2}" y2="${y2}" stroke="rgba(0,0,0,0.1)" stroke-width="1"/>`;
    const lx = cx + (R + 22) * Math.cos(angle);
    const ly = cy + (R + 22) * Math.sin(angle);
    const anchor = Math.abs(Math.cos(angle)) < 0.1 ? "middle" : Math.cos(angle) > 0 ? "start" : "end";
    svg += `<text x="${lx}" y="${ly}" text-anchor="${anchor}" dominant-baseline="central" fill="#444" font-size="11" font-family="var(--font-main)">${RADAR_PROPS[i].label}</text>`;
  }

  // Data polygons
  alloyIds.forEach((id, ai) => {
    const alloy = ALLOYS[id];
    const color = RADAR_COLORS[ai];
    let pts = [];
    for (let i = 0; i < n; i++) {
      const angle = -Math.PI / 2 + i * angleStep;
      const val = alloy[RADAR_PROPS[i].key] / RADAR_PROPS[i].max;
      const r = Math.min(val, 1) * R;
      pts.push(`${cx + r * Math.cos(angle)},${cy + r * Math.sin(angle)}`);
    }
    svg += `<polygon points="${pts.join(" ")}" fill="${color}" fill-opacity="0.12" stroke="${color}" stroke-width="2" stroke-opacity="0.8">
      <animate attributeName="fill-opacity" from="0" to="0.12" dur="0.6s" fill="freeze"/>
    </polygon>`;
    // Dots
    for (let i = 0; i < n; i++) {
      const angle = -Math.PI / 2 + i * angleStep;
      const val = alloy[RADAR_PROPS[i].key] / RADAR_PROPS[i].max;
      const r = Math.min(val, 1) * R;
      svg += `<circle cx="${cx + r * Math.cos(angle)}" cy="${cy + r * Math.sin(angle)}" r="4" fill="${color}" opacity="0.9"/>`;
    }
  });

  svg += `</svg>`;
  chart.innerHTML = svg;

  // Legend
  legend.innerHTML = alloyIds.map((id, i) =>
    `<div class="legend-item"><span class="legend-dot" style="background:${RADAR_COLORS[i]}"></span>${id}</div>`
  ).join("");
}

// ===== COMPARISON TABLE =====
function buildComparisonTable(alloyIds) {
  const head = document.getElementById("table-head");
  const body = document.getElementById("table-body");

  // Header
  head.innerHTML = `<tr><th>Property</th>${alloyIds.map(id => `<th>${id}</th>`).join("")}</tr>`;

  // Find max values for bar scaling
  const alloys = alloyIds.map(id => ALLOYS[id]);

  const numericRows = [
    { cat:"Mechanical Properties" },
    { label:"Tensile Strength (MPa)", key:"tensile", fmt:(a) => `${a.tensileMin} - ${a.tensileMax}`, val:(a) => a.tensileMax },
    { label:"Yield Strength (MPa)", key:"yield", fmt:(a) => `${a.yieldMin} - ${a.yieldMax}`, val:(a) => a.yieldMax },
    { label:"Elongation (%)", key:"elongation", fmt:(a) => `${a.elongation}`, val:(a) => a.elongation },
    { label:"Hardness (Brinell HB)", key:"hardness", fmt:(a) => `${a.hardness}`, val:(a) => a.hardness },
    { cat:"Physical Properties" },
    { label:"Density (g/cm\u00B3)", key:"density", fmt:(a) => `${a.density}`, val:(a) => a.density, invert:true },
    { label:"Melting Range (\u00B0C)", key:"melt", fmt:(a) => `${a.meltMin} - ${a.meltMax}`, val:(a) => a.meltMax },
    { label:"Thermal Conductivity (W/m\u00B7K)", key:"thermal", fmt:(a) => `${a.thermal}`, val:(a) => a.thermal },
    { label:"Electrical Conductivity (%IACS)", key:"electrical", fmt:(a) => `${a.electrical}`, val:(a) => a.electrical },
    { cat:"Ratings" },
    { label:"Corrosion Resistance", key:"corrosion", rating:true },
    { label:"Weldability", key:"weldability", rating:true },
    { label:"Machinability", key:"machinability", rating:true },
    { cat:"Specifications" },
    { label:"Common Tempers", key:"tempers", text:true },
    { label:"Typical Applications", key:"applications", text:true },
    { label:"Equivalent Standards", key:"standards", text:true }
  ];

  let html = "";
  numericRows.forEach(row => {
    if (row.cat) {
      html += `<tr class="prop-category"><td colspan="${alloyIds.length + 1}">${row.cat}</td></tr>`;
      return;
    }

    html += `<tr><td>${row.label}</td>`;
    if (row.rating) {
      alloys.forEach(a => {
        const val = a[row.key];
        const cls = val.toLowerCase();
        html += `<td><span class="rating-badge rating-${cls}"><span class="rating-dot"></span>${val}</span></td>`;
      });
    } else if (row.text) {
      alloys.forEach(a => {
        html += `<td style="text-align:left;font-size:0.8rem;">${a[row.key]}</td>`;
      });
    } else {
      // Numeric with bars
      const vals = alloys.map(a => row.val(a));
      const maxVal = Math.max(...vals);
      alloys.forEach((a, i) => {
        const pct = maxVal > 0 ? (vals[i] / maxVal) * 100 : 0;
        const isBest = vals[i] === maxVal && !row.invert;
        const isLowest = vals[i] === Math.min(...vals) && row.invert;
        html += `<td class="bar-cell"><div class="bar-wrap">
          <span class="bar-value ${isBest || isLowest ? 'best-value' : ''}">${row.fmt(a)}</span>
          <div class="bar-track"><div class="bar-fill" data-width="${pct}" style="width:0%"></div></div>
        </div></td>`;
      });
    }
    html += `</tr>`;
  });

  body.innerHTML = html;
}
</script>
