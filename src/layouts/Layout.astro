---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Far East Metals Development Limited - Aluminum Extrusion, Forging, and Ingot Production. Hong Kong based industry leader since 2003." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body>
  <div class="liquid-bg"></div>
  <a class="skip-link" href="#main-content">Skip to Main Content</a>
  <Navbar />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
</body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 0;
    background: var(--color-accent);
    color: white;
    padding: 8px 16px;
    z-index: 200;
    text-decoration: none;
    font-size: 0.9rem;
  }

  .skip-link:focus {
    top: 0;
  }
</style>
