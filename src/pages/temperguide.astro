                <td>UTS 570 MPa, Yield 505 MPa</td>
              </tr>
              <tr>
                <td class="alloy-cell">7075-T73</td>
                <td>480&deg;C / 1 hr</td>
                <td>Water (RT)</td>
                <td>120&deg;C/6hr + 165&deg;C/24hr</td>
                <td>UTS 500 MPa, Yield 430 MPa</td>
              </tr>
              <tr>
                <td class="alloy-cell">2024-T4</td>
                <td>495&deg;C / 1 hr</td>
                <td>Water (RT)</td>
                <td>Natural age &ge;96 hr</td>
                <td>UTS 470 MPa, Yield 325 MPa</td>
              </tr>
              <tr>
                <td class="alloy-cell">2024-T3</td>
