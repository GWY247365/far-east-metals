---
const rawPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const navItems = [
  { name: 'Home', path: '/' },
  { name: 'About', path: '/about' },
  { name: 'Calculator', path: '/metweighcalculator' },
  { name: 'Contact', path: '/contact' },
];

function isActive(itemPath: string): boolean {
  if (itemPath === '/') return rawPath === '/';
  return rawPath === itemPath || rawPath.startsWith(itemPath + '/');
}
---

<header class="navbar">
  <nav aria-label="Site">
    <div class="nav-inner">
      <a href="/" class="nav-logo" aria-label="Home">
        <img src="/favicon.svg" alt="Far East Metals" width="36" height="36" />
      </a>
      <button class="hamburger" type="button" aria-label="Toggle menu" aria-expanded="false">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
      <ul class="nav-list">
        {navItems.map((item) => (
          <li class="nav-item">
            <a
              href={item.path}
              class:list={['nav-link', { active: isActive(item.path) }]}
            >
              {item.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    padding: 10px 0;
    background: rgba(255, 255, 255, 0.35);
    backdrop-filter: saturate(200%) blur(40px);
    -webkit-backdrop-filter: saturate(200%) blur(40px);
    border-bottom: 0.5px solid rgba(255, 255, 255, 0.4);
    transition: transform 0.3s ease;
  }

  .navbar.hidden {
    transform: translateY(-100%);
  }

  .navbar nav {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .nav-inner {
    display: flex;
    align-items: center;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    padding: 4px 16px 4px 20px;
    flex-shrink: 0;
  }

  .nav-logo img {
    display: block;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px 20px;
    z-index: 101;
  }

  .hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    background: rgba(255, 255, 255, 0.95);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  /* Hamburger animation when open */
  .hamburger.open .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .hamburger.open .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .hamburger.open .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .nav-list {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    list-style: none;
    gap: 0;
    margin: 0;
    padding: 0;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    display: flex;
    align-items: center;
    color: rgba(255, 255, 255, 0.95);
    text-decoration: none;
    font-size: 18px;
    font-weight: 400;
    letter-spacing: normal;
    padding: 14px 20px;
    transition: color 0.3s ease;
    position: relative;
  }

  .nav-link::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: rgba(255, 255, 255, 0.2);
    transition: background 0.3s ease;
  }

  .nav-link.active::before {
    background: var(--color-accent);
  }

  .nav-link:hover {
    color: var(--color-accent);
  }

  .nav-link:hover::before {
    background: var(--color-accent);
  }

  @media (max-width: 768px) {
    .navbar {
      padding: 0;
    }

    .nav-logo {
      padding: 8px 0 8px 16px;
    }

    .nav-logo img {
      width: 30px;
      height: 30px;
    }

    .hamburger {
      display: flex;
      margin-left: auto;
    }

    .nav-list {
      display: none;
      flex-direction: column;
      width: 100%;
      padding: 0 0 10px;
    }

    .nav-list.open {
      display: flex;
    }

    .nav-inner {
      flex-wrap: wrap;
    }

    .nav-item {
      width: 100%;
    }

    .nav-link {
      font-size: 16px;
      padding: 14px 20px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .nav-link::before {
      display: none;
    }

    .nav-link.active {
      color: var(--color-accent);
    }
  }
</style>

<script>
  const navbar = document.querySelector('.navbar');
  const hamburger = document.querySelector('.hamburger');
  const navList = document.querySelector('.nav-list');
  let lastScrollY = window.scrollY;

  // Scroll hide/show
  window.addEventListener('scroll', () => {
    const currentScrollY = window.scrollY;

    if (currentScrollY > lastScrollY && currentScrollY > 80) {
      navbar?.classList.add('hidden');
      // Close menu on scroll hide
      hamburger?.classList.remove('open');
      navList?.classList.remove('open');
      hamburger?.setAttribute('aria-expanded', 'false');
    } else {
      navbar?.classList.remove('hidden');
    }

    lastScrollY = currentScrollY;
  });

  // Hamburger toggle
  hamburger?.addEventListener('click', () => {
    const isOpen = hamburger.classList.toggle('open');
    navList?.classList.toggle('open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
  });

  // Close menu when a link is clicked
  navList?.querySelectorAll('.nav-link').forEach(link => {
    link.addEventListener('click', () => {
      hamburger?.classList.remove('open');
      navList?.classList.remove('open');
      hamburger?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
