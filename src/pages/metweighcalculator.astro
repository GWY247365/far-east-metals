---
import Layout from '../layouts/Layout.astro';
import masterData from '../data/alloys-master.json';

const materialKeys = ['aluminum', 'stainless', 'copper', 'brass', 'zinc', 'titanium', 'nickel', 'magnesium'] as const;
const materials = materialKeys.map(key => {
  const mat = (masterData.materials as Record<string, any>)[key];
  return {
    name: mat.label.replace(' Alloys', '').replace(' Alloy', ''),
    density: mat.defaultDensity,
    color: mat.color,
  };
});
---

<Layout title="Metal Weight Calculator | Far East Metals" description="Free online metal weight calculator. Calculate weight for aluminum, stainless steel, copper, brass, titanium and more. Supports 100+ alloy grades." ogImage="/og-metweighcalculator.png">
  <section class="calculator-page">
    <div class="content-card calc-card">
      <div class="calc-title-bar reveal">
        <svg class="header-svg" viewBox="0 0 400 160" xmlns="http://www.w3.org/2000/svg">
          <!-- Scale base / pillar -->
          <rect x="190" y="80" width="20" height="70" rx="3" fill="#999" stroke="#777" stroke-width="1"/>
          <rect x="160" y="148" width="80" height="10" rx="4" fill="#888" stroke="#666" stroke-width="1"/>
          <!-- Beam -->
          <g class="scale-beam">
            <rect x="80" y="74" width="240" height="8" rx="3" fill="#b0b0b0" stroke="#888" stroke-width="1.2"/>
            <!-- Fulcrum triangle -->
            <polygon points="200,82 192,74 208,74" fill="#999" stroke="#777" stroke-width="1"/>
            <!-- Left pan strings -->
            <line x1="105" y1="82" x2="90" y2="115" stroke="#aaa" stroke-width="1.2"/>
            <line x1="105" y1="82" x2="120" y2="115" stroke="#aaa" stroke-width="1.2"/>
            <!-- Left pan -->
            <ellipse cx="105" cy="118" rx="30" ry="6" fill="#c0c0c0" stroke="#999" stroke-width="1"/>
            <!-- Metal block on left pan -->
            <g class="scale-weight">
              <rect x="90" y="98" width="30" height="18" rx="3" fill="#F5A623" stroke="#d4891a" stroke-width="1.2"/>
              <rect x="90" y="98" width="30" height="5" rx="2" fill="#f7be5e" opacity="0.5"/>
            </g>
            <!-- Right pan strings -->
            <line x1="295" y1="82" x2="280" y2="115" stroke="#aaa" stroke-width="1.2"/>
            <line x1="295" y1="82" x2="310" y2="115" stroke="#aaa" stroke-width="1.2"/>
            <!-- Right pan -->
            <ellipse cx="295" cy="118" rx="30" ry="6" fill="#c0c0c0" stroke="#999" stroke-width="1"/>
          </g>
          <!-- Weight numbers -->
          <text class="weight-text" x="105" y="50" text-anchor="middle" font-size="16" font-weight="600" fill="#F5A623">kg</text>
        </svg>
        <h1 class="page-title">Metal Weight Calculator</h1>
        <p class="page-subtitle">Calculate weight for common metals and alloys across different shapes and dimensions</p>
      </div>
      <div class="calc-section content-card-inner reveal">
        <h3 class="section-heading">Select Material</h3>
        <div class="materials-grid">
          {materials.map((mat) => (
            <button
              class="material-btn"
              data-density={mat.density}
              data-name={mat.name}
              type="button"
            >
              <span class="material-dot" style={`background: ${mat.color};`}></span>
              <span class="material-name">{mat.name}</span>
            </button>
          ))}
        </div>
      </div>

      <div class="calc-section content-card-inner reveal">
        <h3 class="section-heading">Select Grade</h3>
        <div class="grade-dropdown" id="grade-dropdown">
          <button type="button" class="grade-trigger" id="grade-trigger">
            <span id="grade-trigger-text">Select a grade...</span>
            <svg class="grade-arrow" width="12" height="12" viewBox="0 0 12 12"><path fill="#666" d="M6 8L1 3h10z"/></svg>
          </button>
          <div class="grade-panel" id="grade-panel">
            <div class="grade-search-wrap">
              <svg class="grade-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
              <input type="text" class="grade-search" id="grade-search" placeholder="Search grades by name, description, or properties..." />
            </div>
            <div class="grade-list" id="grade-list"></div>
          </div>
        </div>
      </div>

      <div class="calc-section content-card-inner reveal">
        <h3 class="section-heading">Select Shape</h3>
        <div class="shape-dropdown" id="shape-dropdown">
          <button type="button" class="shape-trigger" id="shape-trigger">
            <span class="shape-trigger-content">
              <svg class="shape-preview" viewBox="0 0 40 40" width="28" height="28">
                <ellipse cx="20" cy="10" rx="14" ry="5" fill="none" stroke="#F5A623" stroke-width="1.5"/>
                <line x1="6" y1="10" x2="6" y2="32" stroke="#F5A623" stroke-width="1.5"/>
                <line x1="34" y1="10" x2="34" y2="32" stroke="#F5A623" stroke-width="1.5"/>
                <ellipse cx="20" cy="32" rx="14" ry="5" fill="none" stroke="#F5A623" stroke-width="1.5"/>
              </svg>
              <span id="shape-trigger-text">Solid Cylinder</span>
            </span>
            <svg class="shape-arrow" width="12" height="12" viewBox="0 0 12 12"><path fill="#666" d="M6 8L1 3h10z"/></svg>
          </button>
          <div class="shape-panel" id="shape-panel">
            <div class="shape-options">
              <button type="button" class="shape-option selected" data-shape="cylinder">
                <svg viewBox="0 0 60 50" width="48" height="40">
                  <ellipse cx="30" cy="12" rx="18" ry="7" fill="rgba(245,166,35,0.1)" stroke="#F5A623" stroke-width="1.5"/>
                  <line x1="12" y1="12" x2="12" y2="40" stroke="#F5A623" stroke-width="1.5"/>
                  <line x1="48" y1="12" x2="48" y2="40" stroke="#F5A623" stroke-width="1.5"/>
                  <ellipse cx="30" cy="40" rx="18" ry="7" fill="rgba(245,166,35,0.08)" stroke="#F5A623" stroke-width="1.5"/>
                </svg>
                <span>Solid Cylinder</span>
              </button>
              <button type="button" class="shape-option" data-shape="hollow-cylinder">
                <svg viewBox="0 0 60 50" width="48" height="40">
                  <ellipse cx="30" cy="12" rx="18" ry="7" fill="none" stroke="#F5A623" stroke-width="1.5"/>
                  <ellipse cx="30" cy="12" rx="10" ry="4" fill="none" stroke="#F5A623" stroke-width="1" stroke-dasharray="2,2"/>
                  <line x1="12" y1="12" x2="12" y2="40" stroke="#F5A623" stroke-width="1.5"/>
                  <line x1="48" y1="12" x2="48" y2="40" stroke="#F5A623" stroke-width="1.5"/>
                  <line x1="20" y1="12" x2="20" y2="40" stroke="#F5A623" stroke-width="1" stroke-dasharray="2,2"/>
                  <line x1="40" y1="12" x2="40" y2="40" stroke="#F5A623" stroke-width="1" stroke-dasharray="2,2"/>
                  <ellipse cx="30" cy="40" rx="18" ry="7" fill="none" stroke="#F5A623" stroke-width="1.5"/>
                </svg>
                <span>Hollow Cylinder</span>
              </button>
              <button type="button" class="shape-option" data-shape="rectangular">
                <svg viewBox="0 0 60 50" width="48" height="40">
                  <path d="M10,15 L40,8 L50,15 L20,22 Z" fill="rgba(245,166,35,0.1)" stroke="#F5A623" stroke-width="1.5"/>
                  <path d="M10,15 L10,40 L20,47 L20,22 Z" fill="rgba(245,166,35,0.06)" stroke="#F5A623" stroke-width="1.5"/>
                  <path d="M20,22 L20,47 L50,40 L50,15 Z" fill="rgba(245,166,35,0.03)" stroke="#F5A623" stroke-width="1.5"/>
                </svg>
                <span>Rectangular Bar</span>
              </button>
              <button type="button" class="shape-option" data-shape="sheet">
                <svg viewBox="0 0 60 50" width="48" height="40">
                  <path d="M5,22 L35,15 L55,22 L25,29 Z" fill="rgba(245,166,35,0.1)" stroke="#F5A623" stroke-width="1.5"/>
                  <path d="M5,22 L5,27 L25,34 L25,29 Z" fill="rgba(245,166,35,0.06)" stroke="#F5A623" stroke-width="1.5"/>
                  <path d="M25,29 L25,34 L55,27 L55,22 Z" fill="rgba(245,166,35,0.03)" stroke="#F5A623" stroke-width="1.5"/>
                </svg>
                <span>Sheet / Plate</span>
              </button>
              <button type="button" class="shape-option" data-shape="hex">
                <svg viewBox="0 0 60 50" width="48" height="40">
                  <polygon points="30,5 44,13 44,28 30,36 16,28 16,13" fill="rgba(245,166,35,0.1)" stroke="#F5A623" stroke-width="1.5"/>
                  <line x1="16" y1="28" x2="16" y2="40" stroke="#F5A623" stroke-width="1.5"/>
                  <line x1="30" y1="36" x2="30" y2="48" stroke="#F5A623" stroke-width="1.5"/>
                  <line x1="44" y1="28" x2="44" y2="40" stroke="#F5A623" stroke-width="1.5"/>
                  <line x1="16" y1="40" x2="30" y2="48" stroke="#F5A623" stroke-width="1.5"/>
                  <line x1="30" y1="48" x2="44" y2="40" stroke="#F5A623" stroke-width="1.5"/>
                </svg>
                <span>Hexagonal Bar</span>
              </button>
            </div>
          </div>
        </div>
      </div>

      <div class="calc-section content-card-inner reveal">
        <h3 class="section-heading">Dimensions</h3>
        <div class="unit-row">
          <select id="unit-select">
            <option value="mm">Millimeters (mm)</option>
            <option value="cm">Centimeters (cm)</option>
            <option value="in">Inches (in)</option>
          </select>
        </div>
        <div id="dimension-inputs" class="dimension-inputs">
          <!-- Dynamically filled -->
        </div>
      </div>

      <div class="calc-section content-card-inner results-section" id="results-section" hidden>
        <h3 class="section-heading">Results</h3>
        <div class="results-grid">
          <div class="result-box">
            <span class="result-label">Volume</span>
            <select id="volume-unit">
              <option value="mm3">Cubic Millimeters (mm&sup3;)</option>
              <option value="cm3">Cubic Centimeters (cm&sup3;)</option>
              <option value="in3">Cubic Inches (in&sup3;)</option>
            </select>
            <div class="result-value" id="volume-result">0</div>
          </div>
          <div class="result-box">
            <span class="result-label">Weight</span>
            <select id="weight-unit">
              <option value="g">Grams (g)</option>
              <option value="kg">Kilograms (kg)</option>
              <option value="lb">Pounds (lb)</option>
            </select>
            <div class="result-value" id="weight-result">0.00</div>
          </div>
        </div>
      </div>

      <!-- Disclaimer -->
      <div class="tool-disclaimer reveal">
        <p><strong>Disclaimer:</strong> Calculated weights are theoretical estimates based on nominal alloy densities and ideal geometry. Actual weights may vary due to manufacturing tolerances, alloy composition variations, and surface treatments. Always confirm with your material supplier for procurement quantities. Far East Metals can provide accurate weight calculations for your specific order.</p>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Build grade data from master JSON
  import masterData from '../data/alloys-master.json';

  const PI = Math.PI;
  let selectedDensity = 0; // no density until grade is selected
  let gradeSelected = false;

  const materialKeyMap: Record<string, string> = {
    'Aluminum': 'aluminum',
    'Stainless Steel': 'stainless',
    'Copper': 'copper',
    'Brass': 'brass',
    'Zinc': 'zinc',
    'Titanium': 'titanium',
    'Nickel': 'nickel',
    'Magnesium': 'magnesium',
  };

  const gradeData: Record<string, { category: string; grades: { name: string; desc: string; density: number; tags: string[] }[] }[]> = {};

  for (const [displayName, key] of Object.entries(materialKeyMap)) {
    const mat = (masterData.materials as Record<string, any>)[key];
    if (!mat) continue;
    gradeData[displayName] = mat.groups.map((group: any) => ({
      category: group.name,
      grades: group.alloys.map((alloy: any) => ({
        name: alloy.name,
        desc: alloy.desc || alloy.applications || '',
        density: alloy.density,
        tags: alloy.tags || [],
      })),
    }));
  }

  let currentMaterial = 'Aluminum';

  // Grade dropdown elements
  const gradeDropdown = document.getElementById('grade-dropdown')!;
  const gradeTrigger = document.getElementById('grade-trigger')!;
  const gradeTriggerText = document.getElementById('grade-trigger-text')!;
  const gradePanel = document.getElementById('grade-panel')!;
  const gradeSearch = document.getElementById('grade-search') as HTMLInputElement;
  const gradeList = document.getElementById('grade-list')!;

  function renderGrades(filter = '') {
    const data = gradeData[currentMaterial] || [];
    const lowerFilter = filter.toLowerCase();
    let html = '';

    for (const cat of data) {
      const filtered = cat.grades.filter(g =>
        !filter ||
        g.name.toLowerCase().includes(lowerFilter) ||
        g.desc.toLowerCase().includes(lowerFilter) ||
        g.tags.some(t => t.toLowerCase().includes(lowerFilter))
      );
      if (filtered.length === 0) continue;

      html += `<div class="grade-category">${cat.category}</div>`;
      for (const g of filtered) {
        html += `<button type="button" class="grade-option" data-density="${g.density}" data-name="${g.name}">
          <div class="grade-header"><span class="grade-name">${g.name}</span><span class="grade-density">${g.density} g/cm\u00B3</span></div>
          <div class="grade-desc">${g.desc}</div>
          <div class="grade-tags">${g.tags.map(t => `<span class="grade-tag">${t}</span>`).join('')}</div>
        </button>`;
      }
    }

    if (!html) {
      html = '<div class="grade-empty">No grades found</div>';
    }

    gradeList.innerHTML = html;

    // Bind click events
    gradeList.querySelectorAll('.grade-option').forEach(btn => {
      btn.addEventListener('click', () => {
        const density = parseFloat(btn.getAttribute('data-density')!);
        const name = btn.getAttribute('data-name')!;
        selectedDensity = density;
        gradeSelected = true;
        gradeTriggerText.textContent = name;
        gradeDropdown.classList.remove('open');
        calculate();
      });
    });
  }

  function updateGradesForMaterial() {
    gradeSelected = false;
    selectedDensity = 0;
    gradeTriggerText.textContent = 'Select a grade...';
    gradeSearch.value = '';
    renderGrades();
  }

  // Toggle dropdown
  gradeTrigger.addEventListener('click', () => {
    gradeDropdown.classList.toggle('open');
    if (gradeDropdown.classList.contains('open')) {
      gradeSearch.focus();
    }
  });

  // Search
  gradeSearch.addEventListener('input', () => {
    renderGrades(gradeSearch.value);
  });

  // Close on click outside
  document.addEventListener('click', (e) => {
    if (!gradeDropdown.contains(e.target as Node)) {
      gradeDropdown.classList.remove('open');
    }
  });

  // Material selection
  document.querySelectorAll('.material-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.material-btn').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      selectedDensity = parseFloat(btn.getAttribute('data-density')!);
      currentMaterial = btn.getAttribute('data-name')!;
      updateGradesForMaterial();
      calculate();
    });
  });
  // Select first material by default
  document.querySelector('.material-btn')?.classList.add('selected');

  // Shape dropdown
  const shapeDropdown = document.getElementById('shape-dropdown')!;
  const shapeTrigger = document.getElementById('shape-trigger')!;
  const shapeTriggerText = document.getElementById('shape-trigger-text')!;
  const shapePanel = document.getElementById('shape-panel')!;
  const shapePreview = shapeTrigger.querySelector('.shape-preview')!;
  let currentShape = 'cylinder';

  // Shape SVG icons for the trigger preview
  const shapeSvgs: Record<string, string> = {
    'cylinder': `<ellipse cx="20" cy="10" rx="14" ry="5" fill="none" stroke="#F5A623" stroke-width="1.5"/><line x1="6" y1="10" x2="6" y2="32" stroke="#F5A623" stroke-width="1.5"/><line x1="34" y1="10" x2="34" y2="32" stroke="#F5A623" stroke-width="1.5"/><ellipse cx="20" cy="32" rx="14" ry="5" fill="none" stroke="#F5A623" stroke-width="1.5"/>`,
    'hollow-cylinder': `<ellipse cx="20" cy="10" rx="14" ry="5" fill="none" stroke="#F5A623" stroke-width="1.5"/><ellipse cx="20" cy="10" rx="7" ry="3" fill="none" stroke="#F5A623" stroke-width="1" stroke-dasharray="2,2"/><line x1="6" y1="10" x2="6" y2="32" stroke="#F5A623" stroke-width="1.5"/><line x1="34" y1="10" x2="34" y2="32" stroke="#F5A623" stroke-width="1.5"/><ellipse cx="20" cy="32" rx="14" ry="5" fill="none" stroke="#F5A623" stroke-width="1.5"/>`,
    'rectangular': `<path d="M5,12 L25,6 L35,12 L15,18 Z" fill="rgba(245,166,35,0.1)" stroke="#F5A623" stroke-width="1.5"/><path d="M5,12 L5,30 L15,36 L15,18 Z" fill="rgba(245,166,35,0.06)" stroke="#F5A623" stroke-width="1.5"/><path d="M15,18 L15,36 L35,30 L35,12 Z" fill="rgba(245,166,35,0.03)" stroke="#F5A623" stroke-width="1.5"/>`,
    'sheet': `<path d="M3,17 L23,11 L37,17 L17,23 Z" fill="rgba(245,166,35,0.1)" stroke="#F5A623" stroke-width="1.5"/><path d="M3,17 L3,21 L17,27 L17,23 Z" fill="rgba(245,166,35,0.06)" stroke="#F5A623" stroke-width="1.5"/><path d="M17,23 L17,27 L37,21 L37,17 Z" fill="rgba(245,166,35,0.03)" stroke="#F5A623" stroke-width="1.5"/>`,
    'hex': `<polygon points="20,4 30,10 30,22 20,28 10,22 10,10" fill="rgba(245,166,35,0.1)" stroke="#F5A623" stroke-width="1.5"/><line x1="10" y1="22" x2="10" y2="32" stroke="#F5A623" stroke-width="1.5"/><line x1="20" y1="28" x2="20" y2="38" stroke="#F5A623" stroke-width="1.5"/><line x1="30" y1="22" x2="30" y2="32" stroke="#F5A623" stroke-width="1.5"/><line x1="10" y1="32" x2="20" y2="38" stroke="#F5A623" stroke-width="1.5"/><line x1="20" y1="38" x2="30" y2="32" stroke="#F5A623" stroke-width="1.5"/>`,
  };

  const shapeNames: Record<string, string> = {
    'cylinder': 'Solid Cylinder',
    'hollow-cylinder': 'Hollow Cylinder',
    'rectangular': 'Rectangular Bar',
    'sheet': 'Sheet / Plate',
    'hex': 'Hexagonal Bar',
  };

  shapeTrigger.addEventListener('click', () => {
    shapeDropdown.classList.toggle('open');
  });

  document.addEventListener('click', (e) => {
    if (!shapeDropdown.contains(e.target as Node)) {
      shapeDropdown.classList.remove('open');
    }
  });

  shapePanel.querySelectorAll('.shape-option').forEach(btn => {
    btn.addEventListener('click', () => {
      const shape = (btn as HTMLElement).dataset.shape!;
      currentShape = shape;
      shapeTriggerText.textContent = shapeNames[shape];
      shapePreview.innerHTML = shapeSvgs[shape];
      shapePanel.querySelectorAll('.shape-option').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      shapeDropdown.classList.remove('open');
      renderFields();
      calculate();
    });
  });

  // Compatibility shim so existing code using shapeSelect.value still works
  const shapeSelect = { get value() { return currentShape; } };
  const unitSelect = document.getElementById('unit-select') as HTMLSelectElement;
  const dimInputs = document.getElementById('dimension-inputs')!;

  const shapeFields: Record<string, { label: string; id: string }[]> = {
    'cylinder': [
      { label: 'Diameter', id: 'diameter' },
      { label: 'Length', id: 'length' },
    ],
    'hollow-cylinder': [
      { label: 'Outer Diameter', id: 'outer-diameter' },
      { label: 'Inner Diameter', id: 'inner-diameter' },
      { label: 'Length', id: 'length' },
    ],
    'rectangular': [
      { label: 'Width', id: 'width' },
      { label: 'Height', id: 'height' },
      { label: 'Length', id: 'length' },
    ],
    'sheet': [
      { label: 'Width', id: 'width' },
      { label: 'Length', id: 'length' },
      { label: 'Thickness', id: 'thickness' },
    ],
    'hex': [
      { label: 'Across Flats', id: 'across-flats' },
      { label: 'Length', id: 'length' },
    ],
  };

  function getUnitLabel() {
    const u = unitSelect.value;
    return u === 'mm' ? 'Mm' : u === 'cm' ? 'Cm' : 'In';
  }

  function renderFields() {
    const fields = shapeFields[shapeSelect.value];
    const unit = getUnitLabel();
    dimInputs.innerHTML = fields.map(f =>
      `<div class="dim-field">
        <label>${f.label} (${unit})</label>
        <input type="number" id="${f.id}" placeholder="Enter ${f.label.toLowerCase()}" min="0" step="any" />
      </div>`
    ).join('');
    dimInputs.querySelectorAll('input').forEach(input => {
      input.addEventListener('input', calculate);
    });
  }

  function getVal(id: string): number {
    const el = document.getElementById(id) as HTMLInputElement | null;
    return el ? parseFloat(el.value) || 0 : 0;
  }

  function toMm(val: number): number {
    const unit = unitSelect.value;
    if (unit === 'cm') return val * 10;
    if (unit === 'in') return val * 25.4;
    return val;
  }

  function calculate() {
    const shape = shapeSelect.value;
    let volumeMm3 = 0;

    switch (shape) {
      case 'cylinder': {
        const d = toMm(getVal('diameter'));
        const l = toMm(getVal('length'));
        volumeMm3 = PI * (d / 2) ** 2 * l;
        break;
      }
      case 'hollow-cylinder': {
        const od = toMm(getVal('outer-diameter'));
        const id = toMm(getVal('inner-diameter'));
        const l = toMm(getVal('length'));
        volumeMm3 = PI * ((od / 2) ** 2 - (id / 2) ** 2) * l;
        break;
      }
      case 'rectangular': {
        const w = toMm(getVal('width'));
        const h = toMm(getVal('height'));
        const l = toMm(getVal('length'));
        volumeMm3 = w * h * l;
        break;
      }
      case 'sheet': {
        const w = toMm(getVal('width'));
        const l = toMm(getVal('length'));
        const t = toMm(getVal('thickness'));
        volumeMm3 = w * l * t;
        break;
      }
      case 'hex': {
        const af = toMm(getVal('across-flats'));
        const l = toMm(getVal('length'));
        volumeMm3 = (3 * Math.sqrt(3) / 2) * (af / 2) ** 2 * l;
        break;
      }
    }

    // density is g/cm³, 1 cm³ = 1000 mm³
    const weightG = volumeMm3 * selectedDensity / 1000;

    // Show/hide results section
    const resultsSection = document.getElementById('results-section')!;
    if (volumeMm3 <= 0 || !gradeSelected) {
      resultsSection.hidden = true;
      return;
    }
    resultsSection.hidden = false;

    // Display volume
    const volUnit = (document.getElementById('volume-unit') as HTMLSelectElement).value;
    let displayVol = volumeMm3;
    if (volUnit === 'cm3') displayVol = volumeMm3 / 1000;
    if (volUnit === 'in3') displayVol = volumeMm3 / 16387.064;
    document.getElementById('volume-result')!.textContent =
      displayVol < 0.01 && displayVol > 0 ? displayVol.toExponential(2) : displayVol.toLocaleString('en', { maximumFractionDigits: 2 });

    // Display weight
    const wtUnit = (document.getElementById('weight-unit') as HTMLSelectElement).value;
    let displayWt = weightG;
    if (wtUnit === 'kg') displayWt = weightG / 1000;
    if (wtUnit === 'lb') displayWt = weightG / 453.592;
    document.getElementById('weight-result')!.textContent =
      displayWt.toLocaleString('en', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  // Shape change handled by shape-option click listeners above
  unitSelect.addEventListener('change', () => { renderFields(); calculate(); });
  document.getElementById('volume-unit')!.addEventListener('change', calculate);
  document.getElementById('weight-unit')!.addEventListener('change', calculate);

  renderFields();
  renderGrades();
</script>

