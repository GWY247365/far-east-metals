---
const rawPath = Astro.url.pathname.replace(/\/+$/, '') || '/';
const navItems = [
  { name: 'Home', path: '/' },
  { name: 'About', path: '/about' },
  { name: 'Tools', path: '#', children: [
    { name: 'Weight Calculator', path: '/metweighcalculator' },
    { name: 'Alloy Comparison', path: '/alloycompare' },
    { name: 'Hardness Converter', path: '/hardnessconverter' },
    { name: 'Temper Guide', path: '/temperguide' },
  ]},
  { name: 'Contact', path: '/contact' },
];

function isActive(itemPath: string): boolean {
  if (itemPath === '/') return rawPath === '/';
  return rawPath === itemPath || rawPath.startsWith(itemPath + '/');
}
---

<header class="navbar">
  <nav aria-label="Site">
    <div class="nav-inner">
      <a href="/" class="nav-logo" aria-label="Home">
        <img src="/favicon.svg" alt="Far East Metals" width="52" height="52" />
      </a>
      <button class="hamburger" type="button" aria-label="Toggle menu" aria-expanded="false">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
      <ul class="nav-list">
        {navItems.map((item) => (
          <li class:list={['nav-item', { 'has-dropdown': !!item.children }]}>
            {item.children ? (
              <>
                <button
                  type="button"
                  class:list={['nav-link', 'dropdown-toggle', { active: item.children.some(c => isActive(c.path)) }]}
                  aria-expanded="false"
                >
                  {item.name}
                  <svg class="dropdown-arrow" width="10" height="10" viewBox="0 0 10 10"><path d="M2 4l3 3 3-3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <ul class="dropdown-menu">
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={child.path}
                        class:list={['dropdown-link', { active: isActive(child.path) }]}
                      >
                        {child.name}
                      </a>
                    </li>
                  ))}
                </ul>
              </>
            ) : (
              <a
                href={item.path}
                class:list={['nav-link', { active: isActive(item.path) }]}
              >
                {item.name}
              </a>
            )}
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    padding: 10px 0;
    background: rgba(255, 255, 255, 0.35);
    backdrop-filter: saturate(200%) blur(40px);
    -webkit-backdrop-filter: saturate(200%) blur(40px);
    border-bottom: 0.5px solid rgba(255, 255, 255, 0.4);
    transition: transform 0.3s ease;
    overflow: visible;
  }

  .navbar.hidden {
    transform: translateY(-100%);
  }

  .navbar nav {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .nav-inner {
    display: flex;
    align-items: center;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    padding: 0 10px 0 20px;
    flex-shrink: 0;
  }

  .nav-logo img {
    display: block;
    filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.15));
    transition: transform 0.3s;
  }

  .nav-logo:hover img {
    transform: scale(1.05);
  }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px 20px;
    z-index: 101;
  }

  .hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    background: rgba(255, 255, 255, 0.95);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  /* Hamburger animation when open */
  .hamburger.open .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .hamburger.open .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .hamburger.open .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .nav-list {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    list-style: none;
    gap: 0;
    margin: 0 20px 0 auto;
    padding: 0;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    display: flex;
    align-items: center;
    color: rgba(255, 255, 255, 0.95);
    text-decoration: none;
    font-size: 18px;
    font-weight: 400;
    letter-spacing: normal;
    padding: 14px 20px;
    transition: color 0.3s ease;
    position: relative;
  }

  .nav-link::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: rgba(255, 255, 255, 0.2);
    transition: background 0.3s ease;
  }

  .nav-link.active::before {
    background: var(--color-accent);
  }

  .nav-link:hover {
    color: var(--color-accent);
  }

  .nav-link:hover::before {
    background: var(--color-accent);
  }

  /* Dropdown */
  .dropdown-toggle {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-main);
    gap: 5px;
  }

  .dropdown-arrow {
    transition: transform 0.3s;
    flex-shrink: 0;
  }

  .has-dropdown:hover .dropdown-arrow,
  .has-dropdown.open .dropdown-arrow {
    transform: rotate(180deg);
  }

  .dropdown-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 210px;
    list-style: none;
    padding: 8px 0;
    margin: 0;
    background: rgba(30, 30, 30, 0.85);
    backdrop-filter: saturate(200%) blur(40px);
    -webkit-backdrop-filter: saturate(200%) blur(40px);
    border-radius: 12px;
    border: 0.5px solid rgba(255, 255, 255, 0.15);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
    z-index: 110;
    opacity: 0;
    transform: translateY(-8px);
    transition: opacity 0.25s, transform 0.25s;
  }

  .has-dropdown:hover .dropdown-menu,
  .has-dropdown.open .dropdown-menu {
    display: block;
    opacity: 1;
    transform: translateY(0);
  }

  .dropdown-link {
    display: block;
    padding: 10px 20px;
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    font-size: 15px;
    font-weight: 400;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  .dropdown-link:hover {
    background: rgba(245, 166, 35, 0.15);
    color: var(--color-accent);
  }

  .dropdown-link.active {
    color: var(--color-accent);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .navbar {
      padding: 0;
    }

    .nav-logo {
      padding: 8px 0 8px 16px;
    }

    .nav-logo img {
      width: 30px;
      height: 30px;
    }

    .hamburger {
      display: flex;
      margin-left: auto;
    }

    .nav-list {
      display: none;
      flex-direction: column;
      width: 100%;
      padding: 0 0 10px;
    }

    .nav-list.open {
      display: flex;
    }

    .nav-inner {
      flex-wrap: wrap;
    }

    .nav-item {
      width: 100%;
    }

    .nav-link {
      font-size: 16px;
      padding: 14px 20px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .nav-link::before {
      display: none;
    }

    .nav-link.active {
      color: var(--color-accent);
    }

    .dropdown-menu {
      position: static;
      background: transparent;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      border: none;
      border-radius: 0;
      box-shadow: none;
      padding: 0;
      display: none;
      opacity: 1;
      transform: none;
    }

    .has-dropdown.open .dropdown-menu {
      display: block;
    }

    /* Don't show on hover for mobile */
    .has-dropdown:hover .dropdown-menu {
      display: none;
    }

    .has-dropdown.open:hover .dropdown-menu {
      display: block;
    }

    .dropdown-link {
      padding: 12px 20px 12px 36px;
      font-size: 15px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .dropdown-toggle {
      width: 100%;
      justify-content: space-between;
    }
  }
</style>

<script>
  const navbar = document.querySelector('.navbar');
  const hamburger = document.querySelector('.hamburger');
  const navList = document.querySelector('.nav-list');
  let lastScrollY = window.scrollY;

  // Scroll hide/show
  window.addEventListener('scroll', () => {
    const currentScrollY = window.scrollY;

    if (currentScrollY > lastScrollY && currentScrollY > 80) {
      navbar?.classList.add('hidden');
      // Close menu on scroll hide
      hamburger?.classList.remove('open');
      navList?.classList.remove('open');
      hamburger?.setAttribute('aria-expanded', 'false');
    } else {
      navbar?.classList.remove('hidden');
    }

    lastScrollY = currentScrollY;
  });

  // Hamburger toggle
  hamburger?.addEventListener('click', () => {
    const isOpen = hamburger.classList.toggle('open');
    navList?.classList.toggle('open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
  });

  // Close menu when a nav link (not dropdown toggle) is clicked
  navList?.querySelectorAll('a.nav-link, .dropdown-link').forEach(link => {
    link.addEventListener('click', () => {
      hamburger?.classList.remove('open');
      navList?.classList.remove('open');
      hamburger?.setAttribute('aria-expanded', 'false');
    });
  });

  // Dropdown toggle for mobile
  document.querySelectorAll('.dropdown-toggle').forEach(toggle => {
    toggle.addEventListener('click', () => {
      const parent = toggle.closest('.has-dropdown');
      parent?.classList.toggle('open');
    });
  });
</script>
